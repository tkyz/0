[init]
	defaultBranch = main
[core]
	ignorecase = false
	quotepath = false
	autocrlf = false
	safecrlf = true
	filemode = true
[gpg]
	program = /usr/bin/gpg
[commit]
	gpgsign = true
[color]
	ui = auto
	diff = auto
	status = auto
	branch = auto
[rebase]
	autostash = true
[merge]
	ff = false
[pull]
	ff = only
	rebase = true
[diff "sjis"]
	textconv = iconv -f sjis
[filter "lfs"]
	smudge = git-lfs smudge --skip -- %f
[user]
	name = unknown
	email = unknown
