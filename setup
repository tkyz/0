function _sandbox() {
  (

    image="${ID}:${VERSION_CODENAME:-latest}"

#   kubectl -n 0 run -it --rm --image="${image}" -- bash

    podman run \
      --interactive \
      --tty \
      --rm \
      --name    "0.sandbox.$(uuidgen)" \
      --workdir '/root' \
      --volume  './.cache/pip:/root/.cache/pip' \
      --volume  './.profile:/root/.profile:ro' \
      --volume  './.bashrc:/root/.bashrc:ro' \
      --volume  './setup:/root/setup:ro' \
      --volume  './bin:/root/bin:ro' \
      --volume  './lib:/root/lib:ro' \
      --volume  './opt:/root/opt:ro' \
      --volume  './src:/root/src:ro' \
      --volume  './tmp:/root/tmp' \
      "${ID}:${VERSION_CODENAME:-latest}"
#     --network host \
#     --device  /dev/fuse \
#     --volume  "${PWD}:/root/.pwd:ro" \
#     --env     "UID=$(id -u)" \
#     --env     "DISPLAY=${DISPLAY:-:0.0}" \

  )
}

function _doc() {

  if ! is_x11; then
    return
  fi

  source './.venv/bin/activate'

  cat << EOS | python3 &
from selenium                           import webdriver
from selenium.webdriver.firefox.options import Options

def main():

  opts = Options()
  opts.set_preference('general.useragent.override',    'Mozilla/5.0')
  opts.set_preference('browser.cache.memory.enable',   True)
  opts.set_preference('browser.cache.disk.enable',     False)
  opts.set_preference('browser.tabs.animate',          False)
  opts.set_preference('browser.panorama.animate_zoom', False)
  opts.set_preference('geo.enabled',                   False)

  driver = webdriver.Firefox(opts)
  driver.maximize_window();
  driver.get('http://doc.${tld}/')

if __name__ == '__main__':
  main()
EOS

}

function _llm() {
  (

    source './.venv/bin/activate'
#   python3 -m pip install --upgrade sentencepiece protobuf accelerate
#   python3 -m pip install --upgrade diffusers invisible_watermark transformers accelerate safetensors optimum auto-gptq

#   model='./lib/co.huggingface/stabilityai/japanese-stablelm-base-beta-7b'
#   model='./lib/co.huggingface/stabilityai/japanese-stablelm-base-beta-70b'
#   model='./lib/co.huggingface/stabilityai/japanese-stablelm-base-ja_vocab-beta-7b'
#   model='./lib/co.huggingface/stabilityai/japanese-stablelm-instruct-beta-7b'
#   model='./lib/co.huggingface/stabilityai/japanese-stablelm-instruct-beta-70b'
    model='./lib/co.huggingface/stabilityai/japanese-stablelm-instruct-ja_vocab-beta-7b'

    if [[ -p /dev/stdin ]]; then
      prompt="$(cat /dev/stdin)"
    else
      prompt="$(echo "${@}")"
    fi

    cat << EOS | python3
import os
import torch
from transformers import (
  AutoTokenizer,
  AutoModelForCausalLM
)

def main():

  os.environ["TOKENIZERS_PARALLELISM"] = 'true'

  tokenizer = AutoTokenizer.from_pretrained('${model}')
  model     = AutoModelForCausalLM.from_pretrained('${model}', torch_dtype=torch.float16, low_cpu_mem_usage=True, device_map="auto")

  input_ids = tokenizer.encode(
    """${prompt}""",
    add_special_tokens = True,
    return_tensors     = "pt",
  )

# torch.manual_seed(xxx)

  tokens = model.generate(
    input_ids.to(device=model.device),
    max_new_tokens = 4096,
    temperature    = 0.99,
    top_p          = 0.95,
    do_sample      = True,
  )

  out = tokenizer.decode(tokens[0], skip_special_tokens=True)
  print(out)

if __name__ == '__main__':
  main()
EOS

  )
}

#----------------------------------------------------------------
# main

function main() {
  (
    pushd "${HOME}" &> /dev/null

      if [[ "${BASH_SOURCE:-}" =~ ^.*/fpr$ ]]; then
        arg1="${1:-}"
        shift || true
      else
        arg1='setup'
      fi

      # required
      if [[ 'setup' == "${arg1}" ]]; then
        _etc
        _apt
      fi

      _fpr

      # handle
      if [[ -z "${arg1}" ]]; then
        true

      elif [[ 'setup' == "${arg1}" ]]; then
        _home

      elif [[ 'ext' == "${arg1}" ]]; then
        _apt_ext
        _enc
        _venv
        _src
        _lib
        _opt
        _clean

      elif [[ 'ci' == "${arg1}" ]]; then
#       _llm
#       _k8s
        _build
#       _deploy
        _clean

      elif [[ '-' == "${arg1}" ]]; then
        kind delete clusters --all
        _umnt
        _clean

      # playground
      elif is_func "_${arg1}";                      then "_${arg1}"                     "${@}"
      elif [[ -x "./mnt/${openpgp4fpr}/${arg1}" ]]; then "./mnt/${openpgp4fpr}/${arg1}" "${@}"
#     elif is_cmd "${arg1}";                        then "${arg1}"                      "${@}"
      elif is_cmd java;                             then java -cp ".:./src/0.playground/main/target/classes:./src/0.playground/main/target/dependency/*" Entrypoint "${arg1}" "${@}"
      fi

    popd &> /dev/null
  )
}
main "${@}"
