      arr+=('libgles2-mesa-dev')
      arr+=('libcairo2-dev')
      arr+=('virt-manager')
#     arr+=('winehq-stable')

      ${SUDO} apt-get update
      ${SUDO} apt-get upgrade -y
      ${SUDO} apt-get install -y "${arr[@]}"

    )
  fi

  # ufw
  if is_sudoer && is_cmd ufw; then
    echo y | ${SUDO} ufw enable
    ${SUDO} ufw default deny
#   ${SUDO} ufw allow                                 22
#   ${SUDO} ufw allow from 10.0.0.0/8     to any port 22
#   ${SUDO} ufw allow from 172.16.0.0/12  to any port 22
#   ${SUDO} ufw allow from 192.168.0.0/16 to any port 22
    ${SUDO} ufw reload
    ${SUDO} ufw status verbose
  fi

  # rkhunter
  if is_sudoer && [[ -f '/etc/rkhunter.conf' ]]; then
    ${SUDO} sed -i -r \
      -e 's/^#?LANGUAGE=.*$/LANGUAGE=ja/g' \
      -e 's/^#?UPDATE_LANG=.*$/UPDATE_LANG=ja/g' \
      -e 's/^#?WEB_CMD=.*$/WEB_CMD=""/g' \
      -e 's/^#?UPDATE_MIRRORS=.*$/UPDATE_MIRRORS=1/g' \
      -e 's/^#?MIRRORS_MODE=.*$/MIRRORS_MODE=0/g' \
      -e 's/^#?PKGMGR=.*$/PKGMGR=DPKG/g' \
      '/etc/rkhunter.conf'
  fi
  if is_sudoer && is_cmd rkhunter; then
    set +e
      ${SUDO} rkhunter --update
      ${SUDO} rkhunter --propupd
#     ${SUDO} rkhunter --versioncheck
#     ${SUDO} rkhunter --check --skip-keypress
    set -e
  fi

  # clamav
  if is_sudoer && is_cmd freshclam; then
    ${SUDO} systemctl stop  clamav-freshclam
    ${SUDO} freshclam
    ${SUDO} systemctl start clamav-freshclam
  fi

  # sshd
  if is_sudoer && [[ -f '/etc/ssh/sshd_config' ]]; then
    ${SUDO} sed -i -r \
      -e 's/#?PermitRootLogin .*/PermitRootLogin no/g' \
      -e 's/#?PermitEmptyPasswords .*/PermitEmptyPasswords no/g' \
      -e 's/#?PasswordAuthentication .*/PasswordAuthentication no/g' \
      -e 's/#?PubkeyAuthentication .*/PubkeyAuthentication yes/g' \
      -e 's/#?StrictModes .*/StrictModes yes/g' \
      '/etc/ssh/sshd_config'
  fi
  if ! is_container; then
    ${SUDO} systemctl reload sshd
  fi

  # podman
  if is_sudoer && [[ -f '/etc/containers/registries.conf' ]]; then
    : # echo "unqualified-search-registries = ['container.${domain}', 'docker.io']" | ${SUDO} tee '/etc/containers/registries.conf' > /dev/null
  fi

  # locale
  if is_sudoer && is_cmd locale-gen; then
    ${SUDO} locale-gen ja_JP.UTF-8
    ${SUDO} localedef -f UTF-8 -i ja_JP ja_JP.utf8
    ${SUDO} update-locale LANG='ja_JP.UTF-8'
  fi

  # venv
  if true; then
    (

      venv_dir='./.venv'

      python3 -m venv "${venv_dir}"

      source "${venv_dir}/bin/activate"

      req_file="${venv_dir}/requirements.txt"
      touch "${req_file}"

      tmp_file="${req_file}.tmp"
      {
        echo pip
        echo yq
        cat "${req_file}"
        pip freeze | sed -e 's/[!=<> #].*//g'
      } 2> /dev/null | sort -u > "${tmp_file}"
      mv "${tmp_file}" "${req_file}"

      pip install --upgrade --requirement "${req_file}"

    )
  fi

}

function _fpr() {

  if unset openpgp4fpr 2> /dev/null; then

    (

      fpr="$(gpgconf --list-options gpg | grep default-key | cut -d ':' -f 10 | sed -r 's/.*"=?(0x)?//')"
      if [[ -z "${fpr}" ]]; then
        fpr="$(gpg --with-colons --list-secret-keys | grep -A 1 ^sec: | grep ^fpr: | cut -d ':' -f 10 | sort | head -n 1 || true)"
      fi
      if [[ -z "${fpr}" ]]; then

        passphrase=''

        export TZ='utc'

        cmds=()
        cmds+=('faketime' '-f' "${unix_epoch}")
        cmds+=('gpg' '--no-tty' '--pinentry-mode' 'loopback' '--passphrase' "${passphrase}")

        "${cmds[@]}" --quick-generate-key "${uuid}" ed25519 sign,cert 0

        fpr="$(gpg --with-colons --list-secret-keys "=${uuid}" 2> /dev/null | grep ^fpr | cut -d ':' -f 10)"

        "${cmds[@]}" --quick-add-key    "0x${fpr}" ed25519 sign 0
#       "${cmds[@]}" --quick-add-key    "0x${fpr}" ed25519 cert 0
        "${cmds[@]}" --quick-add-key    "0x${fpr}" cv25519 encr 0
        "${cmds[@]}" --quick-add-key    "0x${fpr}" ed25519 auth 0

        "${cmds[@]}" --quick-add-uid    "0x${fpr}" "${fpr}"
#       "${cmds[@]}" --quick-add-uid    "0x${fpr}" "${user}@$(hostname -f)"
        "${cmds[@]}" --quick-revoke-uid "0x${fpr}" "${uuid}"

      fi

      conf_file="${GNUPGHOME:-${home}/.gnupg}/gpg.conf"
      grep -q default-key       "${conf_file}" && sed -i -r -e "s/^(default-key).*/\1       0x${fpr}/g" "${conf_file}" || echo "default-key       0x${fpr}" >> "${conf_file}"
      grep -q default-recipient "${conf_file}" && sed -i -r -e "s/^(default-recipient).*/\1 0x${fpr}/g" "${conf_file}" || echo "default-recipient 0x${fpr}" >> "${conf_file}"

    )

    openpgp4fpr="$(gpgconf --list-options gpg | grep default-key | cut -d ':' -f 10 | sed -r 's/.*"=?(0x)?//')"
    readonly openpgp4fpr
    export   openpgp4fpr

  fi

  if ! is_venv; then
    source './.venv/bin/activate'
  fi

}

function _enc() {

  if [[ ! -p '/dev/stdin' ]]; then
    echo -n "${@}" | _enc
    return
  fi

# cat '/dev/stdin' | openssl enc -aes-256-cbc -pbkdf2 -salt | base64 --wapp 0
# cat '/dev/stdin' | gpg --symmetric                        | base64 --wrap 0
  cat '/dev/stdin' | gpg --encrypt                          | base64 --wrap 0

} 2> /dev/null

function _dec() {

  if [[ ! -p '/dev/stdin' ]]; then
    echo -n "${@}" | _dec
    return
  fi

  cat '/dev/stdin' | base64 --decode | gpg --decrypt

} 2> /dev/null

function _mnt() {
  (

    mnt_key="${1:-}"
    mnt_dir="${2:-./mnt/${mnt_key}}"

    # list...
    if [[ -z "${mnt_key}" || -z "${mnt_dir}" ]]; then
      _list | while read key; do
        _mnt "${key}"
      done
      return
    fi

    if is_mnt "${mnt_dir}"; then
      return
    fi

    base_dir="./src/0.fpr/${mnt_key}"
    enc_dir="${base_dir}/enc"
    gpw_file="${base_dir}/gpw"

    # uuid
    if [[ "${mnt_key}" =~ ^[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{12}$ ]] && is_sudoer; then

      dev_uuid="${mnt_key}"
      blk_info="$(lsblk --all --fs --json --paths | jq -cr ".. | objects | select(.uuid == \"${dev_uuid}\")")"
      name="$(  echo "${blk_info}" | jq -cr '.name')"
      fstype="$(echo "${blk_info}" | jq -cr '.fstype')"

      if [[ 'crypto_LUKS' == "${fstype}" ]]; then
 
        if [[ ! -f "${gpw_file}" ]]; then
          return
        fi

        map_dir="/dev/mapper/${dev_uuid}"
        if [[ -e "${map_dir}" ]]; then
          return
        fi

        gpg --decrypt "${gpw_file}" | ${SUDO} cryptsetup open --type luks "${name}" "${dev_uuid}" || true

      elif [[ -n "${fstype}" ]]; then

        mnt_opts=()
#       mnt_opts+=('vers=2.0')
#       mnt_opts+=('defaults')
#       mnt_opts+=('iocharset=utf8')
#       mnt_opts+=('nounix')
#       mnt_opts+=('dir_mode=0700')
#       mnt_opts+=('file_mode=0600')
#       mnt_opts+=("uid=$(id -u)")
#       mnt_opts+=("gid=$(id -g)")
#       mnt_opts+=('ro')
#       if [[ -n "${user}" && -n "${pass}" ]]; then
#
#         credentials="$(mktemp)"
#         echo "username=${user}" >> "${credentials}"
#         echo "password=${pass}" >> "${credentials}"
#
#         mnt_opts+=("credentials=${credentials}")
#
#       fi
        mnt_opts="$(IFS=,; echo "${mnt_opts[*]}")"

        mkdir -p "${mnt_dir}"
        ${SUDO} mount --options "${mnt_opts}" UUID="${dev_uuid}" "${mnt_dir}" || rm -d "${mnt_dir}"

      fi

    # fpr
    elif [[ "${mnt_key}" =~ ^[0-9a-fA-F]{40}$ ]]; then

      mkdir -p \
        "${enc_dir}" \
        "${mnt_dir}"

      # init
      conf_file_org="${enc_dir}/gocryptfs.conf"
      conf_file_gpg="${conf_file_org}.gpg"
      test ! -f "${gpw_file}"                                      && cat /dev/urandom | tr --complement --delete '[:graph:]' | head -c 2048 | gpg --encrypt --throw-keyids > "${gpw_file}"      || true
      test ! -f "${conf_file_org}" &&   test -f "${conf_file_gpg}" && cat "${conf_file_gpg}"                                                 | gpg --decrypt                > "${conf_file_org}" || true
      test ! -f "${conf_file_org}" && ! test -f "${conf_file_gpg}" && gocryptfs -extpass 'gpg' -extpass '--decrypt' -extpass "${gpw_file}" -init "${enc_dir}"
      test   -f "${conf_file_org}" && ! test -f "${conf_file_gpg}" && cat "${conf_file_org}"                                                 | gpg --encrypt --throw-keyids > "${conf_file_gpg}" || true

      gocryptfs \
        -extpass 'gpg' \
        -extpass '--decrypt' \
        -extpass "${gpw_file}" \
        "${enc_dir}" \
        "${mnt_dir}" || rm -d "${mnt_dir}"

    fi

  )
}

function _umnt() {
  (

    mnt_key="${1:-}"
    mnt_dir="./mnt/${mnt_key}"

    # list...
    if [[ -z "${mnt_key}" ]]; then
      _list | while read key; do
        _umnt "${key}"
      done
      return
    fi

    if ! is_mnt "${mnt_dir}"; then
      return
    fi

    # uuid
    if [[ "${mnt_key}" =~ ^[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{12}$ ]] && is_sudoer; then

      dev_uuid="${mnt_key}"
      blk_info="$(lsblk --all --fs --json --paths | jq -cr ".. | objects | select(.uuid == \"${dev_uuid}\")")"
      fstype="$(echo "${blk_info}" | jq -cr '.fstype')"

      if [[ 'crypto_LUKS' == "${fstype}" ]]; then
        ${SUDO} cryptsetup close "${dev_uuid}" || true

      else
        ${SUDO} fusermount -u "${mnt_dir}" && rm -d "${mnt_dir}" || true
      fi

    # fpr
    elif [[ "${mnt_key}" =~ ^[0-9a-fA-F]{40}$ ]]; then
      fusermount -u "${mnt_dir}" && rm -d "${mnt_dir}" || true
    fi

  )
}

function _k8s() {
  (
    if ! is_wsl && ! is_container && is_sudoer && is_cmd kind && is_cmd kubectl; then

      kind delete cluster --name "${domain}" || true

      ${SUDO} sysctl --write fs.inotify.max_user_instances=1024     #  128
      ${SUDO} sysctl --write fs.inotify.max_user_watches=65536      # 8192
      ${SUDO} sysctl --write net.ipv4.ip_unprivileged_port_start=53 # 1024
      cat './src/0.kind/kind.yml' | env_replace | KIND_EXPERIMENTAL_PROVIDER=podman kind create cluster --name "${domain}" --config -
      ${SUDO} sysctl --write net.ipv4.ip_unprivileged_port_start=1024

      kubectl config set-context     "kind-${domain}"
      kubectl cluster-info --context "kind-${domain}"

      kubectl get configmap kube-proxy --namespace kube-system --output yaml | sed 's/strictARP: false/strictARP: true/' | kubectl apply -f -

      # loadbalancer
#     cat                   './src/com.github/metallb/metallb/config/manifests/metallb-native.yaml'         | kubectl apply -f -
      curl 'https://raw.githubusercontent.com/metallb/metallb/v0.14.9/config/manifests/metallb-native.yaml' | kubectl apply -f -

      # ingress
#     cat                   './src/com.github/kubernetes/ingress-nginx/deploy/static/provider/kind/deploy.yaml'                    | kubectl apply -f -
      curl 'https://raw.githubusercontent.com/kubernetes/ingress-nginx/controller-v1.12.1/deploy/static/provider/kind/deploy.yaml' | kubectl apply -f -

      # dashboard
#     cat                   './src/com.github/kubernetes/dashboard/aio/deploy/recommended.yaml'        | kubectl apply -f -
#     curl 'https://raw.githubusercontent.com/kubernetes/dashboard/v2.7.0/aio/deploy/recommended.yaml' | kubectl apply -f -

      kubectl delete namespace "${hostname}" 2> /dev/null || true
      kubectl create namespace "${hostname}"              || true

    fi
  )
}

function _validate() {
  (
    git grep --cached -n \
      -e "${user}"                               --or \
      -e "${home}"                               --or \
      -e "${domain}"                             --or \
      -e "${hostname}"                           --or \
      -e "${openpgp4fpr}"                        --or \
      -e "${resolve}"                            --or \
      -e "${external_ip}"                        --or \
      -e '-----BEGIN PRIVATE KEY-----'           --or \
      -e '-----BEGIN RSA PRIVATE KEY-----'       --or \
      -e '-----BEGIN PGP PRIVATE KEY BLOCK-----' --or \
      -e '-----BEGIN OPENSSH PRIVATE KEY-----'   --or \
      -e 'TODO:' || true
  )
}

function _build() {
  (

    src_key="${1:-}"

    if [[ -z "${src_key}" ]]; then
      find './src' -name 'Makefile' -or -name 'build.xml' -or -name 'pom.xml' -or -name 'package.json' -or -name 'Dockerfile' | while read item; do
        _build "$(echo "${item}" | sed -r 's|^\./src/(.*)/[^/]+$|\1|g')"
      done
      return
    fi

    [[ "${src_key}" =~ ^com\.github/.*$   ]] && return || true
    [[ "${src_key}" =~ ^com\.gitlab/.*$   ]] && return || true
    [[ "${src_key}" =~ ^org\.golang/.*$   ]] && return || true
    [[ "${src_key}" =~ ^0\.playground/.*$ ]] && return || true

    pushd "./src/${src_key}" &> /dev/null

      echo '---'
      pwd

      if [[ -f './Makefile' ]]; then
        true
      fi

      if [[ -f './build.xml' ]]; then
        true
      fi
      if [[ -f './pom.xml' ]]; then

        MAVEN_OPTS='-Xms256m -Xmx256m -XX:-UsePerfData'

        opts=()
        opts+=('--threads' '1C')
        opts+=('--define'  "version=${tag}")
        opts+=('--define'  'checkstyle.skip=false')
        opts+=('--define'  'maven.test.skip=false')
        opts+=('--define'  'maven.javadoc.skip=false')
        opts+=('--define'  'assembly.skipAssembly=true')

        mvn "${opts[@]}" clean package # deploy

      fi

      if [[ -f './package.json' ]]; then
        true
#       npm install
#       npm run build
      fi

      if [[ -f './Dockerfile' ]]; then

        image="container.${domain}/${src_key}:${tag}"
        if [[ -z "$(podman images --noheading "${image}")" ]]; then

          opts=()
          opts+=('--tag' "${image}")
          opts+=('--pull')
#         opts+=('--no-cache')

          podman build "${opts[@]}" .
#         if ping -c 1 -W 3 'container.0' &> /dev/null; then
#           podman push --tls-verify=false "${image}" || true
#         fi

        fi

      fi

    popd &> /dev/null

  )
}

function _deploy() {
  (

    src_key="${1:-}"

    if [[ -z "${src_key}" ]]; then
      find './src' -name 'deploy.yml' | while read item; do
        _deploy "$(echo "${item}" | sed -r 's|^\./src/(.*)/[^/]+$|\1|g')"
      done
      return
    fi

    test ! -f "./src/${src_key}/deploy.yml" && return || true

    pushd "./src/${src_key}" &> /dev/null

      echo '---'
      pwd

      yq -cr '.. | objects | select(.image != null) | .image' deploy.yml | env_replace | while read image; do

        if [[ -z "$(podman images --noheading "${image}")" ]]; then
          continue
        fi
        if podman exec "${domain}-control-plane" crictl images | awk -F ' ' '{print $1":"$2}' | grep -q "${image}"; then
          continue
        fi

        tmpfile="$(mktemp)"
        podman save --format oci-archive "${image}" --output "${tmpfile}"
        kind load image-archive --name "${domain}" "${tmpfile}" || true
        rm "${tmpfile}"

      done

#     kubectl -n "${hostname}" rollout restart deploy "${src_key##*.}" || \
      ( cat './deploy.yml' | env_replace | kubectl apply -f - )

    popd &> /dev/null

  )
}

function _clean() {

  if is_sudoer; then
    ${SUDO} apt-get autoremove -y
    ${SUDO} apt-get clean
  fi

  if is_cmd podman; then
    podman system  prune --force || true
    podman volume  prune --force || true
    podman network prune --force || true
  fi
  if is_cmd docker; then
    docker system  prune --force || true
    docker volume  prune --force || true
    docker network prune --force || true
  fi
  if is_cmd pip3; then
    pip3 cache purge
  fi

}


function _mkqr() {
  echo '---'
  echo    "openpgp4fpr:${openpgp4fpr}"
  echo -n "openpgp4fpr:${openpgp4fpr}" | qrencode --type ansi
  echo '---'
  echo    "http://doc.${domain}/"
  echo -n "http://doc.${domain}/"      | qrencode --type ansi
  echo -n "http://doc.${domain}/"      | qrencode --type png --output './doc/logo.png'
}

function _sandbox() {
  (

    image="${ID}:${VERSION_CODENAME:-latest}"

    opts=()
    opts+=('--interactive')
    opts+=('--tty')
    opts+=('--rm')
    opts+=('--name'     "${domain}.sandbox.${uuid}")
    opts+=('--hostname' "${uuid}.sandbox.${domain}")
#   opts+=('--network'  'host')
#   opts+=('--env'      "UID=$(id -u)")
    opts+=('--workdir'  '/root')
    opts+=('--volume'   "${home}:/root")
    # fuse
    opts+=('--device'   '/dev/fuse')
    opts+=('--cap-add'  'SYS_ADMIN')
    # x11
    opts+=('--env'      "DISPLAY=${DISPLAY:-:0.0}")
    opts+=('--volume'   '/tmp/.X11-unix/X0:/tmp/.X11-unix/X0')

    podman run "${opts[@]}" "${image}"
#   kubectl -n 0 run -it --rm --image="${image}" -- bash

  )
}

function _browse() {

  if ! is_x11; then
    return
  fi

  cat << EOS | python3 &
from selenium                           import webdriver
from selenium.webdriver.firefox.options import Options

def main():

  opts = Options()
  opts.set_preference('general.useragent.override',    'Mozilla/5.0')
  opts.set_preference('browser.cache.memory.enable',   True)
  opts.set_preference('browser.cache.disk.enable',     False)
  opts.set_preference('browser.tabs.animate',          False)
  opts.set_preference('browser.panorama.animate_zoom', False)
  opts.set_preference('geo.enabled',                   False)

  driver = webdriver.Firefox(opts)
  driver.maximize_window();
  driver.get('${1}')

if __name__ == '__main__':
  main()
EOS

}

function _llm() {
  (

    if [[ -n "${1:-}" ]]; then
      echo "${@}" | _llm
      return
    fi

    script_file="$(mktemp)"
    cat << EOS > "${script_file}"
import os
import sys
import re
import time
import regex
import torch

from transformers import (
  AutoTokenizer,
  AutoModelForCausalLM,
  TextStreamer,
  Trainer,
  TrainingArguments,
  DataCollatorForLanguageModeling,
)
from datasets import Dataset

list_file  = './list'
model_path = './lib/0.llm/7b'

def gen(tokenizer, model, prompt, max=4096):

  prompt = """${llm_prompt:-}""" + prompt

  embed_tokens(tokenizer, model, prompt)

  streamer   = TextStreamer(tokenizer, skip_prompt=True, skip_special_tokens=True)
  input_ids  = tokenizer.encode(prompt, add_special_tokens=False, return_tensors='pt')
  output_ids = model.generate(input_ids.to(device=model.device), max_new_tokens=max, temperature=1.0, top_p=1.0, do_sample=True, streamer=streamer)

# print(tokenizer.convert_ids_to_tokens(input_ids[0]))
# print(tokenizer.convert_ids_to_tokens(output_ids[0]))
# embed_tokens(tokenizer, model, tokenizer.decode(input_ids[0]))
  embed_tokens(tokenizer, model, tokenizer.decode(output_ids[0]))

def embed_tokens(tokenizer, model, prompt):

  split_regex = r'[\s\t\r\n\+\-\*/=%_\.:,;\"\'\^\~\(\)\[\]\{\}<>\`\?$&\|#@!0-9\\\\、。！？：；（）「」＜＞＿]+'

  tokens  = set()
  tokens |= {os.environ.get('openpgp4fpr')}
  tokens |= set(re.split(split_regex, prompt))
  tokens |= set(regex.findall(r'\X', prompt))
  if os.path.isfile(list_file):
    with open(list_file, 'r', encoding="UTF-8") as f:
      data    = f.read()
#     tokens |= set(data.splitlines())
      tokens |= set(re.split(split_regex, data))
      tokens |= set(regex.findall(r'\X', data))
  if os.path.isfile('./.bash_history'):
    with open('./.bash_history', 'r', encoding="UTF-8") as f:
      data    = f.read()
#     tokens |= set(data.splitlines())
      tokens |= set(re.split(split_regex, data))
      tokens |= set(regex.findall(r'\X', data))
  if os.path.isfile('./setup'):
    with open('./setup', 'r', encoding="UTF-8") as f:
      data    = f.read()
#     tokens |= set(data.splitlines())
      tokens |= set(re.split(split_regex, data))
      tokens |= set(regex.findall(r'\X', data))

  tokens |= set(filter(lambda s: '' != s, tokens))
  tokens |= {'\s', '\t', '\r', '\n', ' '}
  tokens  = list(tokens)
  tokens  = sorted(tokens)
  tokens  = sorted(tokens, key=len, reverse=True)

  if 0 < tokenizer.add_tokens(tokens):
    model.resize_token_embeddings(len(tokenizer), mean_resizing=True)

def main():

  tokenizer = AutoTokenizer.from_pretrained(model_path)
  model     = AutoModelForCausalLM.from_pretrained(model_path, torch_dtype='auto', device_map='auto', local_files_only=True)

  while True:

    prompt = sys.stdin.readline()
    if '' == prompt:
      break

    try:
      gen(tokenizer, model, prompt)
    except KeyboardInterrupt as e:
      print(e)
      continue

if __name__ == '__main__':
  main()
EOS
    python3 "${script_file}" 2> /dev/null || true

    rm "${script_file}"

  )
}

#----------------------------------------------------------------
# main

function main() {
  (
    pushd "${home}" &> /dev/null

      if ! is_mnt './fpr'; then

        _deps
        _fpr
#       _mnt
        _mnt "${openpgp4fpr}" './fpr'

        fork "${hash}"
        exit

      fi
      _fpr

      arg1="${1:-}"
      shift || true

      # handle
      if [[ -z "${arg1}" ]]; then
        true

      elif [[ "${#arg1}" -ge 4 && "${openpgp4fpr}" =~ ^${arg1} ]]; then
        main "${hash}"

      elif [[ "${arg1}" == "${hash}" ]]; then

        # imp
        main "fpr_${openpgp4fpr}"
        main "https://github.com/${github_user}.keys"
        main "https://github.com/${github_user}.gpg"

        # exp
        gpg --with-colons --list-keys | grep -A 1 ^pub: | grep ^fpr: | cut -d ':' -f 10 | while read fpr; do
#         gpg               --export-secret-keys         --output "./${fpr}.key"           "0x${fpr}"
          gpg --batch --yes --export             --armor --output "./src/0.fpr/${fpr}/pub" "0x${fpr}"
        done

        chmod    go-rwx '.'        &> /dev/null || true
        chmod -R go-rwx './.gnupg' &> /dev/null || true
        chmod -R go-rwx './.ssh'   &> /dev/null || true

        git config --global init.defaultBranch main
        git config --global core.ignorecase    false
        git config --global core.quotepath     false
        git config --global core.autocrlf      false
        git config --global core.safecrlf      true
        git config --global core.filemode      true
        git config --global core.hooksPath     '~/.git-hooks'
        git config --global color.ui           auto
        git config --global color.diff         auto
        git config --global color.status       auto
        git config --global color.branch       auto
        git config --global pull.ff            only
        git config --global pull.rebase        true
        git config --global pull.autostash     false
        git config --global rebase.autostash   false
        git config --global merge.ff           false
        git config --global diff.sjis.textconv 'iconv -f sjis'
        git config --global filter.lfs.smudge  'git-lfs smudge --skip -- %f'
#       git config --global user.name          "${user}"
#       git config --global user.email         "${user}@$(hostname -f)"
        git config --global user.signingkey    "$(gpg --with-colons --list-secret-keys "0x${openpgp4fpr}" | grep -A 1 :s: | grep ^fpr: | cut -d : -f 10)"
        git config --global gpg.program        "$(type -p gpg)"
        git config --global commit.gpgsign     true

        main license
        main .

        main list | grep -E -e '^(https?|git)://.*\.git$' | while read uri; do
          main "${uri}"
        done

        main k8s
#       main ci
#       main cd

      elif [[ '.' == "${arg1}" ]]; then
        main mkqr
        main '0'
        main '0.fpr'

      elif [[ "${arg1}" == '0' ]]; then

        git_dir="${home}/lib/0.git/${arg1}.git"

#       git init --bare --object-format=sha256 "${git_dir}" || true
        git init --bare                        "${git_dir}" || true

        type_git '.' 'origin'   "${git_dir}"
#       type_git '.' 'upstream' "git://git.${domain}/${arg1}.git"
#       type_git '.' 'upstream' "ssh://${user}@git.${domain}/${arg1}.git"
#       type_git '.' 'github'   "https://github.com/${github_user}/${arg1}.git"
#       type_git '.' 'github'   "ssh://git@github.com/${github_user}/${arg1}.git"

      elif [[ "${arg1}" == '0.fpr' ]]; then

        git_dir="${home}/lib/0.git/${arg1}.git"

#       git init --bare --object-format=sha256 "${git_dir}" || true
        git init --bare                        "${git_dir}" || true

        type_git "./src/${arg1}" 'origin'   "${git_dir}"
#       type_git "./src/${arg1}" 'upstream' "git://git.${domain}/${arg1}.git"
#       type_git "./src/${arg1}" 'upstream' "ssh://${user}@git.${domain}/${arg1}.git"
#       type_git "./src/${arg1}" 'github'   "https://github.com/${github_user}/${arg1}.git"
#       type_git "./src/${arg1}" 'github'   "ssh://git@github.com/${github_user}/${arg1}.git"

      elif [[ 'ci' == "${arg1}" ]]; then
        main validate
        main build
#       main push
#       main test

      elif [[ 'cd' == "${arg1}" ]]; then
        main deploy

      elif [[ '-' == "${arg1}" ]]; then
        kind delete clusters --all
        main umnt
        main clean

      elif is_func "_${arg1}"; then
        "_${arg1}" "${@}"

      elif [[ -n "$(podman images --noheading "container.${domain}/${arg1}:${tag}")" ]]; then
        podman run -it --rm "container.${domain}/${arg1}:${tag}" "${@}"

      elif is_cmd wine && [[ -f "${arg1}" && "${arg1}" =~ ^.*\.exe$ ]]; then
        wine "${arg1}" "${@}"

#     elif [[ "${arg1}" =~ ^[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{12}$ ]]; then
#     elif [[ "${arg1}" =~ ^[0-9a-fA-F]{40}$ ]]; then

      elif [[ "${arg1}" =~ ^https://github\.com/.+\.keys$ ]]; then
        {
          cat './.ssh/authorized_keys'
          curl -fsSL "${arg1}"
        } | sort -u | tee './.ssh/authorized_keys' #&> /dev/null

      elif [[ "${arg1}" =~ ^https://github\.com/.+\.gpg$ ]]; then
        curl -fsSL "${arg1}" | gpg --import || true

      elif [[ "${arg1}" =~ ^git://.+\.git$ ]]; then
        true

      elif [[ "${arg1}" =~ ^https://github\.com/.+\.git$ ]]; then

        git_dir='./src'
        git_dir+="/$(echo "${arg1}" | sed -E 's|^https://([^/]+)/(.+)\.git$|\1|g' | tr '.' $'\n' | tac | paste -s -d '.')"
        git_dir+="/$(echo "${arg1}" | sed -E 's|^https://([^/]+)/(.+)\.git$|\2|g')"

        type_git "${git_dir}" 'github' "${arg1}"

      elif [[ "${arg1}" =~ ^https://gitlab\.com/.+\.git$ ]]; then

        git_dir='./src'
        git_dir+="/$(echo "${arg1}" | sed -E 's|^https://([^/]+)/(.+)\.git$|\1|g' | tr '.' $'\n' | tac | paste -s -d '.')"
        git_dir+="/$(echo "${arg1}" | sed -E 's|^https://([^/]+)/(.+)\.git$|\2|g')"

        type_git "${git_dir}" 'gitlab' "${arg1}"

      elif [[ "${arg1}" =~ ^https://huggingface\.co/.+\.git$ ]]; then

        git_dir='./lib'
        git_dir+="/$(echo "${arg1}" | sed -E 's|^https://([^/]+)/(.+)\.git$|\1|g' | tr '.' $'\n' | tac | paste -s -d '.')"
        git_dir+="/$(echo "${arg1}" | sed -E 's|^https://([^/]+)/(.+)\.git$|\2|g')"

        type_git "${git_dir}" 'huggingface' "${arg1}"

      else
        false
      fi

    popd &> /dev/null
  )
}
main "${@}"
