#!/bin/bash

set -o errexit
set -o nounset
set -o pipefail

umask 0022

if true; then

  readonly unix_epoch='1970-01-01 00:00:00 +0000'
  readonly fqdn="${USER:-root}@$(hostname -f)"

  readonly github_user='tkyz'
  readonly github_mail="36824716+${github_user}@users.noreply.github.com"

fi

#----------------------------------------------------------------
# dependencies
if [[ 0 == "$(id -u)" ]]; then

  arr=()
  arr+=('gnupg2')
  arr+=('openssl')
  arr+=('uuid-runtime')
  arr+=('bash')
  arr+=('curl')
  arr+=('git')

  apt update
  apt upgrade -y
  apt install -y "${arr[@]}"

  unset arr

fi

#----------------------------------------------------------------
# openpgp4fpr

if ! openpgp4fpr &> /dev/null; then

  readonly gpg_dummy_uid="$(cat /dev/urandom | tr -d -c '[:alnum:]' | head -c 63 || true)"
# readonly gpg_dummy_uid="$(uuidgen)"

  # 後で変更させる
  readonly passphrase=''
# readonly passphrase="${gpg_dummy_uid}"
# readonly passphrase="$(cat /dev/urandom | tr -d -c '[:alnum:]' | head -c 63 || true)"

  # 事前準備が必要な状況がある
  mkdir -p "${HOME}/.gnupg/private-keys-v1.d"
  chmod -R go-rwx "${HOME}/.gnupg"

  gpg --no-tty --pinentry-mode loopback --passphrase "${passphrase}" --quick-generate-key "${gpg_dummy_uid}" rsa4096 sign,cert 0

  openpgp4fpr="$(gpg --list-secret-keys --with-colons ="${gpg_dummy_uid}" | grep ^fpr | cut -d ':' -f 10)"

  gpg --no-tty --pinentry-mode loopback --passphrase "${passphrase}" --quick-add-uid    ="${gpg_dummy_uid}" "${openpgp4fpr}"
  gpg --no-tty --pinentry-mode loopback --passphrase "${passphrase}" --quick-add-uid    ="${gpg_dummy_uid}" "${USER:-root} <${fqdn}>"
  gpg --no-tty --pinentry-mode loopback --passphrase "${passphrase}" --quick-revoke-uid ="${openpgp4fpr}"   "${gpg_dummy_uid}"

  gpg --no-tty --pinentry-mode loopback --passphrase "${passphrase}" --quick-add-key "${openpgp4fpr}" rsa4096 sign 0
# gpg --no-tty --pinentry-mode loopback --passphrase "${passphrase}" --quick-add-key "${openpgp4fpr}" rsa4096 cert 0
  gpg --no-tty --pinentry-mode loopback --passphrase "${passphrase}" --quick-add-key "${openpgp4fpr}" rsa4096 encr 0
  gpg --no-tty --pinentry-mode loopback --passphrase "${passphrase}" --quick-add-key "${openpgp4fpr}" rsa4096 auth 0

  # TODO: cross-certify

  colddir="${HOME}/.gnupg_cold_${openpgp4fpr}_${fqdn}"
  fprdir="${HOME}/src/0.gpg/${openpgp4fpr}"

  printf "cold key. \e[2m%s\e[0m\n" "${colddir}"

  gpg --passphrase "${passphrase}" --armor --export-secret-keys ="${openpgp4fpr}"                                                               > "${colddir}/mst"
  gpg --passphrase "${passphrase}" --armor --export             ="${openpgp4fpr}"                                                               > "${colddir}/pub" # mstから発行可能
  echo -n "${openpgp4fpr}" | gpg --recipient ="${openpgp4fpr}" --encrypt --armor                                                                > "${colddir}/fpr"
  sed -z 's/.*:-----BEGIN PGP PUBLIC KEY BLOCK-----/-----BEGIN PGP PUBLIC KEY BLOCK-----/' "${HOME}/.gnupg/openpgp-revocs.d/${openpgp4fpr}.rev" > "${colddir}/rev"

  # masterkeyを削除
  rm "${HOME}/.gnupg/private-keys-v1.d/$(gpg --list-secret-keys --with-colons ="${openpgp4fpr}" | grep ^grp | head -n 1 | cut -d ':' -f 10).key"

  cp "${colddir}/pub" "${fprdir}/pub"
  cp "${colddir}/fpr" "${fprdir}/fpr"

fi

readonly openpgp4fpr="${openpgp4fpr:-$(openpgp4fpr)}"
readonly signingkey="$(gpg --list-secret-keys --with-colons ="${openpgp4fpr}" | grep -A 1 :s: | grep ^fpr | cut -d ':' -f 10)"

#----------------------------------------------------------------
# gitconfig

# /etc/gitconfig
if [[ 0 == "$(id -u)" ]]; then
  git config --system init.defaultBranch main
  git config --system core.ignorecase    false
  git config --system core.quotepath     false
  git config --system core.autocrlf      false
  git config --system core.safecrlf      true
  git config --system core.filemode      true
  git config --system gpg.program        "$(type -p gpg)"
  git config --system commit.gpgsign     true
  git config --system color.ui           auto
  git config --system color.diff         auto
  git config --system color.status       auto
  git config --system color.branch       auto
  git config --system merge.ff           false
  git config --system pull.ff            only
  git config --system pull.rebase        true
  git config --system diff.sjis.textconv 'iconv -f sjis'
  git config --system alias.graph        'log --all --graph --pretty=format:"<%H> %ad [%an] %cd [%cn] %G? %Cgreen%d%Creset %s" --date=short --date-order'
fi

# ${HOME}/.gitconfig
if true; then
  git config --global user.name          "${openpgp4fpr}"
  git config --global user.email         'unknown'
  git config --global user.signingkey    "${signingkey}!"
fi

#----------------------------------------------------------------
# git clone

function _git-remote-set() {
  git remote add "${@}" 2> /dev/null || git remote set-url "${@}"
}

function _git-clone() {

  local -r clone_dir="${1}"
  local -r repos_dir="${2}"
  local -r repo_name="${3}"

  local -r bare_dir="${repos_dir}/${repo_name}"

  mkdir -p "${clone_dir}" "${repos_dir}"
  pushd "${clone_dir}"

    # TODO: --object-format=sha256
    git init
    git init --bare "${bare_dir}"

#   _git-remote-set upstream "https://git.0/${repo_name}"
    _git-remote-set upstream "git://git.0/${repo_name}"
#   _git-remote-set upstream "ssh://git.0/${repo_name}"
    _git-remote-set origin   "${bare_dir}"
    _git-remote-set github   "https://github.com/${github_user}/${repo_name}"
    _git-remote-set github   "ssh://git@github.com/${github_user}/${repo_name}"

    git fetch --all --prune || true

    local -r curr_branch="$(git branch --show-current)"
    if [[ -n "${curr_branch}" ]]; then
      git branch --move "${curr_branch}_$(date "+%Y%m%d_%H%M%S_%N")"
    fi

    # main branch
    if   git rev-parse upstream/main &> /dev/null; then git checkout -b main upstream/main
    elif git rev-parse origin/main   &> /dev/null; then git checkout -b main origin/main
    elif git rev-parse github/main   &> /dev/null; then git checkout -b main github/main
    else

      git checkout --orphan main

      # /dev/null 4b825dc642cb6eb9a060e54bf8d69288fbee4904
      # root-commit
      git \
        commit \
          --message "${openpgp4fpr}" \
          --allow-empty

      git push origin main

    fi

    git branch --set-upstream-to=upstream/main main || \
    git branch --set-upstream-to=origin/main   main || \
    git branch --set-upstream-to=github/main   main

    for remote in $(git remote); do
      git remote set-head "${remote}" main || true
    done

    # TODO: The following untracked working tree files would be overwritten by merge:
#   for remote in $(git remote); do
#     git merge  --allow-unrelated-histories "${remote}/main" || true
##    git rebase                             "${remote}/main" || true
#   done

  popd

}

_git-clone "${HOME}"                   "${HOME}/.0/${openpgp4fpr}/git" '0.git'
_git-clone "${HOME}/.0/${openpgp4fpr}" "${HOME}/.0/${openpgp4fpr}/git" "${openpgp4fpr}.git"

unset -f \
  _git-remote-set \
  _git-close

if [[ 0 == "$(id -u)" ]]; then
  ln -fsn "${HOME}/.git" '/.git'
fi

# 0.git hooks
pushd "${HOME}"
  hooksdir="${HOME}/.git-hooks"
  git config --local core.hooksPath "${hooksdir}"
  ln -fs "${hooksdir}/pre-receive"  "$(git remote get-url origin)/hooks/pre-receive"
  ln -fs "${hooksdir}/update"       "$(git remote get-url origin)/hooks/update"
  ln -fs "${hooksdir}/post-receive" "$(git remote get-url origin)/hooks/post-receive"
popd

# TODO: cmdrc.bat
if false && is_wsl; then
  reg add "HKEY_CURRENT_USER\Software\Microsoft\Command Processor"
    /v AutoRun
    /t REG_SZ
    /d "\"%%USERPROFILE%%\cmdrc.bat\""
    /f
fi
