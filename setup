function _deps() {

  # /etc/wsl.conf
  if is_sudoer && is_wsl; then
    cat << EOS | ${SUDO} tee /etc/wsl.conf > /dev/null
[automount]
options            = "uid=0,gid=0,umask=0077,fmask=0177,metadata"
[network]
#generateResolvConf = false
[interop]
enabled            = false
appendWindowsPath  = false
[user]
default            = root
EOS
  fi

  # /etc/default/keyboard
  if is_sudoer; then
    cat << EOS | ${SUDO} tee /etc/default/keyboard > /dev/null
XKBMODEL=pc105
XKBLAYOUT=jp
XKBVARIANT=
XKBOPTIONS=ctrl:nocaps
BACKSPACE=guess
EOS
  fi

  # apt
  if is_sudoer && is_deb; then

    # /etc/apt/apt.conf.d/00default
    echo 'APT::Default-Release "stable";' | ${SUDO} tee /etc/apt/apt.conf.d/00default > /dev/null

    # /etc/apt/sources.list
    cat << EOS | ${SUDO} tee /etc/apt/sources.list > /dev/null
deb     http://deb.debian.org/debian               ${VERSION_CODENAME}           main contrib non-free non-free-firmware
deb-src http://deb.debian.org/debian               ${VERSION_CODENAME}           main contrib non-free non-free-firmware
deb     http://deb.debian.org/debian               ${VERSION_CODENAME}-updates   main contrib non-free non-free-firmware
deb-src http://deb.debian.org/debian               ${VERSION_CODENAME}-updates   main contrib non-free non-free-firmware
deb     http://deb.debian.org/debian               ${VERSION_CODENAME}-backports main contrib non-free non-free-firmware
deb-src http://deb.debian.org/debian               ${VERSION_CODENAME}-backports main contrib non-free non-free-firmware
deb     http://security.debian.org/debian-security ${VERSION_CODENAME}-security  main contrib non-free non-free-firmware
deb-src http://security.debian.org/debian-security ${VERSION_CODENAME}-security  main contrib non-free non-free-firmware
#deb     http://deb.debian.org/debian               testing                       main contrib non-free non-free-firmware
#deb-src http://deb.debian.org/debian               testing                       main contrib non-free non-free-firmware
#deb     http://deb.debian.org/debian               unstable                      main contrib non-free non-free-firmware
#deb-src http://deb.debian.org/debian               unstable                      main contrib non-free non-free-firmware
#deb     http://deb.debian.org/debian               experimental                  main contrib non-free non-free-firmware
#deb-src http://deb.debian.org/debian               experimental                  main contrib non-free non-free-firmware
EOS

    (

      arr=()
      # shell
      arr+=('bash')
      arr+=('bash-completion')
#     arr+=('zsh')
#     arr+=('fish')
      # hw
      if ! is_container; then
        arr+=('lshw')
        arr+=('lsscsi')
        arr+=('usbutils')
      fi
      # fw
      if ! is_container; then
        arr+=('firmware-linux')
        arr+=('firmware-realtek')
        arr+=('firmware-iwlwifi')
      fi
      # vol
      if ! is_container; then
        arr+=('parted')
        arr+=('cryptsetup')
        arr+=('lvm2')
      fi
      # fuse
      arr+=('fuse')
      arr+=('archivemount')
      arr+=('cifs-utils')
      arr+=('gocryptfs')
      # archive
      arr+=('libarchive-tools')
      arr+=('unar')
      arr+=('zip')
      # print
      arr+=('cups')
      # git
      arr+=('git')
      arr+=('git-crypt')
      arr+=('git-lfs')
      # python
      arr+=('python3')
      arr+=('python3-pip')
      arr+=('python3-venv')
      # container
      if ! is_container; then
        arr+=('podman')
        arr+=('containerd.io')
      fi

      arr+=('uuid-runtime')
      arr+=('faketime')
      arr+=('gnupg2')
      arr+=('openssl')
      arr+=('openssh-client')
      arr+=('openssh-server')
      if ! is_container; then
        arr+=('ufw')
        arr+=('rkhunter')
        arr+=('clamav')
      fi

      arr+=('util-linux')
      arr+=('procps')
      arr+=('rsync')
      arr+=('xsel')
      arr+=('pkg-config')
      arr+=('parallel')
      arr+=('gettext-base')
      arr+=('nkf')
      arr+=('jq')
      arr+=('htop')
      arr+=('curl')
      arr+=('tmux')
      arr+=('qrencode')

      arr+=('vim')
#     arr+=('emacs')

      arr+=('nmap')
      arr+=('tcpdump')

      ${SUDO} apt-get update
      ${SUDO} apt-get upgrade -y
      ${SUDO} apt-get install -y "${arr[@]}"
#     ${SUDO} apt list --upgradable

    )

  fi

}

function _fpr() {
  if unset openpgp4fpr 2> /dev/null; then

    (

      fpr="$(gpgconf --list-options gpg | grep default-key | cut -d ':' -f 10 | sed -r 's/.*"=?(0x)?//')"
      if [[ -z "${fpr}" ]]; then
        fpr="$(gpg --with-colons --list-secret-keys | grep -A 1 ^sec: | grep ^fpr: | cut -d ':' -f 10 | sort | head -n 1 || true)"
      fi
      if [[ -z "${fpr}" ]]; then

        uuid="$(uuidgen)"
        passphrase=''

        export TZ='utc'

        cmds=()
        cmds+=('faketime' '-f' "${unix_epoch}")
        cmds+=('gpg' '--no-tty' '--pinentry-mode' 'loopback' '--passphrase' "${passphrase}")

        "${cmds[@]}" --quick-generate-key "${uuid}" ed25519 sign,cert 0

        fpr="$(gpg --with-colons --list-secret-keys "=${uuid}" 2> /dev/null | grep ^fpr | cut -d ':' -f 10)"

        "${cmds[@]}" --quick-add-key    "0x${fpr}" ed25519 sign 0
#       "${cmds[@]}" --quick-add-key    "0x${fpr}" ed25519 cert 0
        "${cmds[@]}" --quick-add-key    "0x${fpr}" cv25519 encr 0
        "${cmds[@]}" --quick-add-key    "0x${fpr}" ed25519 auth 0

        "${cmds[@]}" --quick-add-uid    "0x${fpr}" "${fpr}"
#       "${cmds[@]}" --quick-add-uid    "0x${fpr}" "${user}@$(hostname -f)"
        "${cmds[@]}" --quick-revoke-uid "0x${fpr}" "${uuid}"

      fi

      conf_file="${GNUPGHOME:-${home}/.gnupg}/gpg.conf"
      grep -q default-key       "${conf_file}" && sed -i -r -e "s/^(default-key).*/\1       0x${fpr}/g" "${conf_file}" || echo "default-key       0x${fpr}" >> "${conf_file}"
      grep -q default-recipient "${conf_file}" && sed -i -r -e "s/^(default-recipient).*/\1 0x${fpr}/g" "${conf_file}" || echo "default-recipient 0x${fpr}" >> "${conf_file}"

    )

    openpgp4fpr="$(gpgconf --list-options gpg | grep default-key | cut -d ':' -f 10 | sed -r 's/.*"=?(0x)?//')"
    readonly openpgp4fpr
    export   openpgp4fpr

  fi
}

function _home() {
  (

    git config --global init.defaultBranch main
    git config --global core.ignorecase    false
    git config --global core.quotepath     false
    git config --global core.autocrlf      false
    git config --global core.safecrlf      true
    git config --global core.filemode      true
    git config --global core.hooksPath     '~/.git-hooks'
    git config --global gpg.program        "$(type -p gpg)"
    git config --global commit.gpgsign     true
    git config --global color.ui           auto
    git config --global color.diff         auto
    git config --global color.status       auto
    git config --global color.branch       auto
    git config --global pull.ff            only
    git config --global pull.rebase        true
    git config --global pull.autostash     false
    git config --global rebase.autostash   false
    git config --global merge.ff           false
    git config --global diff.sjis.textconv 'iconv -f sjis'
    git config --global filter.lfs.smudge  'git-lfs smudge --skip -- %f'
#   git config --global user.name          "${user}"
#   git config --global user.email         "${user}@$(hostname -f)"
    git config --global user.signingkey    "$(gpg --with-colons --list-secret-keys "0x${openpgp4fpr}" | grep -A 1 :s: | grep ^fpr: | cut -d : -f 10)"

    repos=()
    repos+=('0')
    repos+=('0.fpr')

    for repo in "${repos[@]}"; do

      src_dir="./src/${repo}"
      if [[ '0' == "${repo}" ]]; then
        src_dir="${home}"
      fi

      mkdir -p "${src_dir}"
      pushd "${src_dir}" &> /dev/null

        echo '---'
        pwd

#       git init --object-format=sha256
        git init

        git remote add 'origin'   "${home}/lib/0.git/${repo}.git"                   2> /dev/null || git remote set-url 'origin'   "${home}/lib/0.git/${repo}.git"
        git remote add 'upstream' "git://git.0/${repo}.git"                         2> /dev/null || git remote set-url 'upstream' "git://git.0/${repo}.git"
#       git remote add 'upstream' "ssh://${user}@git.0/${repo}.git"                 2> /dev/null || git remote set-url 'upstream' "ssh://${user}@git.0/${repo}.git"
        git remote add 'github'   "https://github.com/${github_user}/${repo}.git"   2> /dev/null || git remote set-url 'github'   "https://github.com/${github_user}/${repo}.git"
#       git remote add 'github'   "ssh://git@github.com/${github_user}/${repo}.git" 2> /dev/null || git remote set-url 'github'   "ssh://git@github.com/${github_user}/${repo}.git"
        git fetch --all --prune || true
        git remote | while read remote; do
          git remote set-head "${remote}" 'main' || true
        done

#       git init --bare --object-format=sha256 "$(git remote get-url 'origin')" || true
        git init --bare                        "$(git remote get-url 'origin')" || true

        git checkout --orphan 'main' || true

        # origin/main
        if git rev-parse --verify 'origin/main' &> /dev/null; then
          git reset  --mixed           'origin/main'
          git branch --set-upstream-to='origin/main'
        fi

        # root-commit
        if ! git rev-parse --verify HEAD 2> /dev/null; then

          date="${unix_epoch} +0000"

          GIT_COMMITTER_DATE="${date}" \
          GIT_AUTHOR_DATE="${date}" \
            git \
              -c user.name="${openpgp4fpr}" \
              -c user.email="${openpgp4fpr}" \
              commit \
                --allow-empty \
                --message 'root-commit'

        fi

        git gc

      popd &> /dev/null

    done

  )
}

function _apt() {

  if ! is_sudoer; then
    return
  fi

  (

    # tor           https://support.torproject.org/apt/
    # nvidia        https://nvidia.github.io/nvidia-container-runtime/
    # k8s           https://kubernetes.io/ja/docs/setup/production-environment/tools/kubeadm/install-kubeadm/
    # nordvpn       https://support.nordvpn.com/hc/ja/articles/20196094470929
    # bigtop
    # docker        https://docs.docker.com/engine/install/debian/
    # google-cloud  https://cloud.google.com/storage/docs/gcsfuse-install
    # google-chrome
    # bazel
    # dotnet        https://learn.microsoft.com/ja-jp/dotnet/core/install/linux-debian
    # unity         https://docs.unity3d.com/hub/manual/InstallHub.html
    # virtualbox    https://www.virtualbox.org/wiki/Linux_Downloads
    # winehq        https://gitlab.winehq.org/wine/wine/-/wikis/Debian-Ubuntu

    curl -fsSL 'https://deb.torproject.org/torproject.org/A3C4F0F979CAA22CDBA8F512EE8CBC9E886DDD89.asc' | ${SUDO} gpg --dearmor --yes --output /etc/apt/keyrings/org.torproject.gpg
    curl -fsSL 'https://pkgs.k8s.io/core:/stable:/v1.32/deb/Release.key'                                | ${SUDO} gpg --dearmor --yes --output /etc/apt/keyrings/io.k8s.pkgs.gpg
    curl -fsSL 'https://nvidia.github.io/libnvidia-container/gpgkey'                                    | ${SUDO} gpg --dearmor --yes --output /etc/apt/keyrings/com.nvidia.gpg
    curl -fsSL 'https://repo.nordvpn.com/gpg/nordvpn_public.asc'                                        | ${SUDO} gpg --dearmor --yes --output /etc/apt/keyrings/com.nordvpn.gpg
#   curl -fsSL 'https://dlcdn.apache.org/bigtop/bigtop-3.3.0/repos/GPG-KEY-bigtop'                      | ${SUDO} gpg --dearmor --yes --output /etc/apt/keyrings/org.apache.bigtop.gpg
#   curl -fsSL "https://download.docker.com/linux/${ID}/gpg"                                            | ${SUDO} gpg --dearmor --yes --output /etc/apt/keyrings/com.docker.download.gpg
    curl -fsSL 'https://packages.cloud.google.com/apt/doc/apt-key.gpg'                                  | ${SUDO} gpg --dearmor --yes --output /etc/apt/keyrings/com.google.cloud.packages.gpg
#   curl -fsSL 'https://dl-ssl.google.com/linux/linux_signing_key.pub'                                  | ${SUDO} gpg --dearmor --yes --output /etc/apt/keyrings/com.google.gpg
#   curl -fsSL 'https://bazel.build/bazel-release.pub.gpg'                                              | ${SUDO} gpg --dearmor --yes --output /etc/apt/keyrings/build.bazel.gpg
    curl -fsSL 'https://packages.microsoft.com/keys/microsoft.asc'                                      | ${SUDO} gpg --dearmor --yes --output /etc/apt/keyrings/com.microsoft.gpg
    curl -fsSL 'https://hub.unity3d.com/linux/keys/public'                                              | ${SUDO} gpg --dearmor --yes --output /etc/apt/keyrings/com.unity.gpg
    curl -fsSL 'https://www.virtualbox.org/download/oracle_vbox_2016.asc'                               | ${SUDO} gpg --dearmor --yes --output /etc/apt/keyrings/org.virtualbox.gpg
    curl -fsSL 'https://dl.winehq.org/wine-builds/winehq.key'                                           | ${SUDO} gpg --dearmor --yes --output /etc/apt/keyrings/org.winehq.gpg

    # /etc/apt/sources.list.d/*
    echo "deb     [signed-by=/etc/apt/keyrings/org.torproject.gpg                        ] https://deb.torproject.org/torproject.org                             ${VERSION_CODENAME}                  main"    | ${SUDO} tee    /etc/apt/sources.list.d/org.torproject.list            > /dev/null
#   echo "deb-src [signed-by=/etc/apt/keyrings/org.torproject.gpg                        ] https://deb.torproject.org/torproject.org                             ${VERSION_CODENAME}                  main"    | ${SUDO} tee -a /etc/apt/sources.list.d/org.torproject.list            > /dev/null
#   echo "deb     [signed-by=/etc/apt/keyrings/org.torproject.gpg                        ] https://deb.torproject.org/torproject.org                             tor-experimental-${VERSION_CODENAME} main"    | ${SUDO} tee -a /etc/apt/sources.list.d/org.torproject.list            > /dev/null
#   echo "deb-src [signed-by=/etc/apt/keyrings/org.torproject.gpg                        ] https://deb.torproject.org/torproject.org                             tor-experimental-${VERSION_CODENAME} main"    | ${SUDO} tee -a /etc/apt/sources.list.d/org.torproject.list            > /dev/null
#   echo "deb     [signed-by=/etc/apt/keyrings/org.torproject.gpg                        ] https://deb.torproject.org/torproject.org                             tor-nightly-main-${VERSION_CODENAME} main"    | ${SUDO} tee -a /etc/apt/sources.list.d/org.torproject.list            > /dev/null
#   echo "deb-src [signed-by=/etc/apt/keyrings/org.torproject.gpg                        ] https://deb.torproject.org/torproject.org                             tor-nightly-main-${VERSION_CODENAME} main"    | ${SUDO} tee -a /etc/apt/sources.list.d/org.torproject.list            > /dev/null
    echo 'deb     [signed-by=/etc/apt/keyrings/io.k8s.pkgs.gpg                           ] https://pkgs.k8s.io/core:/stable:/v1.32/deb/                          /'                                            | ${SUDO} tee    /etc/apt/sources.list.d/io.k8s.pkgs.list               > /dev/null
