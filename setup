  # /etc/apt/*
  if is_sudoer && is_deb; then
    (

      echo 'APT::Default-Release "stable";' | ${SUDO} tee /etc/apt/apt.conf.d/00default > /dev/null

      cat << EOS | ${SUDO} tee /etc/apt/sources.list > /dev/null
