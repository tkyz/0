: << 'END_OF_BATCH'
@rem ================================ windows batch [ms932, crlf] ================================
@echo off

setlocal

  cd /d "%USERPROFILE%"

  set dist=debian

  wsl --unregister %dist%
  wsl --set-default-version 2
  wsl --install --distribution %dist%

  wsl --terminate    %dist%
  wsl --set-version  %dist% 2
  wsl --distribution %dist% -- sed -i 's#:/root:#:/mnt/c/Users/%USERNAME%:#' /etc/passwd
  wsl --distribution %dist% -- $^( wslpath -u %~0 ^)
  wsl --terminate    %dist%

endlocal
exit /b
END_OF_BATCH
# ================================ linux shell script [utf8, lf] ================================

set -o errexit
set -o nounset
set -o pipefail

(

  set -a
    source '/etc/os-release'
  set +a

  test 'debian' == "${ID_LIKE:-${ID}}"
  test 'bash'   == "${SHELL##*/}"

  #----------------------------------------------------------------
  # function

  function _deps() {
    (

      cat << EOS | ${SUDO} tee '/etc/apt/sources.list.d/org.debian.list' > '/dev/null'
deb     http://deb.debian.org/debian               ${VERSION_CODENAME}           main contrib non-free non-free-firmware
deb-src http://deb.debian.org/debian               ${VERSION_CODENAME}           main contrib non-free non-free-firmware
deb     http://deb.debian.org/debian               ${VERSION_CODENAME}-updates   main contrib non-free non-free-firmware
deb-src http://deb.debian.org/debian               ${VERSION_CODENAME}-updates   main contrib non-free non-free-firmware
deb     http://deb.debian.org/debian               ${VERSION_CODENAME}-backports main contrib non-free non-free-firmware
deb-src http://deb.debian.org/debian               ${VERSION_CODENAME}-backports main contrib non-free non-free-firmware
deb     http://security.debian.org/debian-security ${VERSION_CODENAME}-security  main contrib non-free non-free-firmware
deb-src http://security.debian.org/debian-security ${VERSION_CODENAME}-security  main contrib non-free non-free-firmware
#deb     http://deb.debian.org/debian               testing                       main contrib non-free non-free-firmware
#deb-src http://deb.debian.org/debian               testing                       main contrib non-free non-free-firmware
#deb     http://deb.debian.org/debian               unstable                      main contrib non-free non-free-firmware
#deb-src http://deb.debian.org/debian               unstable                      main contrib non-free non-free-firmware
#deb     http://deb.debian.org/debian               experimental                  main contrib non-free non-free-firmware
#deb-src http://deb.debian.org/debian               experimental                  main contrib non-free non-free-firmware
EOS

      ${SUDO} apt-get update
      ${SUDO} apt-get upgrade -y
      ${SUDO} apt-get install -y curl gnupg2 gettext-base

      cat << EOS | sed -e 's/#.*$//g' -e '/^$/d' | while read item; do
com.nvidia           https://nvidia.github.io/libnvidia-container/gpgkey                                    https://nvidia.github.io/libnvidia-container/stable/deb/\$(ARCH) /                                   # https://nvidia.github.io/nvidia-container-runtime/
org.virtualbox       https://www.virtualbox.org/download/oracle_vbox_2016.asc                               https://download.virtualbox.org/virtualbox/${ID}                 ${VERSION_CODENAME}         contrib # https://www.virtualbox.org/wiki/Linux_Downloads
com.unity            https://hub.unity3d.com/linux/keys/public                                              https://hub.unity3d.com/linux/repos/deb                          stable                      main    # https://docs.unity3d.com/hub/manual/InstallHub.html
org.winehq           https://dl.winehq.org/wine-builds/winehq.key                                           https://dl.winehq.org/wine-builds/${ID}                          ${VERSION_CODENAME}         main    # https://gitlab.winehq.org/wine/wine/-/wikis/Debian-Ubuntu
org.torproject       https://deb.torproject.org/torproject.org/A3C4F0F979CAA22CDBA8F512EE8CBC9E886DDD89.asc https://deb.torproject.org/torproject.org                        ${VERSION_CODENAME}         main    # https://support.torproject.org/little-t-tor/getting-started/installing/
io.k8s.pkgs          https://pkgs.k8s.io/core:/stable:/v1.36/deb/Release.key                                https://pkgs.k8s.io/core:/stable:/v1.36/deb/                     /                                   # https://kubernetes.io/docs/setup/production-environment/tools/kubeadm/install-kubeadm/
com.google.cloud-sdk https://packages.cloud.google.com/apt/doc/apt-key.gpg                                  https://packages.cloud.google.com/apt                            cloud-sdk                   main    # https://cloud.google.com/sdk/docs/install#deb
com.microsoft.code   https://packages.microsoft.com/keys/microsoft.asc                                      https://packages.microsoft.com/repos/code                        stable                      main    # https://code.visualstudio.com/docs/setup/linux
com.github           https://cli.github.com/packages/githubcli-archive-keyring.gpg                          https://cli.github.com/packages                                  stable                      main    # https://github.com/cli/cli/blob/trunk/docs/install_linux.md#debian
com.nordvpn          https://repo.nordvpn.com/gpg/nordvpn_public.asc                                        https://repo.nordvpn.com/deb/nordvpn/${ID}                       stable                      main    # https://support.nordvpn.com/hc/ja/articles/20196094470929
#com.google.gcsfuse   https://packages.cloud.google.com/apt/doc/apt-key.gpg                                  https://packages.cloud.google.com/apt                            gcsfuse-${VERSION_CODENAME} main
#com.google.chrome    https://dl-ssl.google.com/linux/linux_signing_key.pub                                  https://dl.google.com/linux/chrome/deb                           stable                      main
#com.microsoft.dotnet https://packages.microsoft.com/keys/microsoft.asc                                      https://packages.microsoft.com/${ID}/${VERSION_ID}/prod          ${VERSION_CODENAME}         main    # https://learn.microsoft.com/ja-jp/dotnet/core/install/linux-debian
#com.docker           https://download.docker.com/linux/${ID}/gpg                                            https://download.docker.com/linux/${ID}                          ${VERSION_CODENAME}         stable  # https://docs.docker.com/engine/install/debian/
EOS

        name="$(  echo "${item}" | sed -r 's/^([^ ]+)[ ]+([^ ]+)[ ]+(.*)$/\1/')"
        pub="$(   echo "${item}" | sed -r 's/^([^ ]+)[ ]+([^ ]+)[ ]+(.*)$/\2/')"
        source="$(echo "${item}" | sed -r 's/^([^ ]+)[ ]+([^ ]+)[ ]+(.*)$/\3/' | xargs)"

        pub_file="/etc/apt/keyrings/${name}.gpg"
        src_file="/etc/apt/sources.list.d/${name}.list"

        if [[ -f "${pub_file}" && -f "${src_file}" ]]; then
          continue
        fi

        curl -fsSL "${pub}"                          | ${SUDO} tee "${pub_file}" > '/dev/null'
        echo "deb [signed-by=${pub_file}] ${source}" | ${SUDO} tee "${src_file}" > '/dev/null'

      done
      ${SUDO} apt-get update

      cat << EOS | sed -e 's/#.*$//g' | xargs ${SUDO} apt-get install -y
# apt

  # shell
    bash bash-completion
#   zsh
#   fish

  # hw
    lshw
    lsscsi
    usbutils

  # gpu
    nvidia-container-toolkit
    nvidia-kernel-dkms
    nvidia-driver
    nvidia-driver-libs
    nvidia-detect
    nvidia-smi

  # fw
    firmware-linux
    firmware-realtek
    firmware-iwlwifi

  # fs
    parted
    cryptsetup
    lvm2
    gocryptfs

  # fuse
    fuse
    archivemount
    cifs-utils
    smbclient

  # net
    openssl
    openssh-client
    openssh-server
    curl
    wget
    ncat
    nmap
    tcpdump

  # time
    ntpsec-ntpdate
    faketime

  # vpn
    openvpn
#   strongswan
#   wireguard
#   nordvpn

  # pcsc
    pcscd
    pcsc-tools
    libpcsclite-dev
    opensc
    libccid
    libnfc-bin

  # archive
    libarchive-tools
    unar
    zip

  # util
    util-linux
    procps
    pkg-config
    uuid-runtime
    gettext
    gnupg2
    tmux
    jq
    qrencode
    imagemagick
    rsync
    xsel
    parallel
    nkf
    htop
    cups
    faketime
    moreutils
    aria2
    ffmpeg
    libcairo2
    build-essential
    libglfw3-dev
    libgles2-mesa-dev
    libcairo2-dev
    autoconf
    libtool
    libssl-dev

    ufw
    rkhunter
    clamav

  # editor
    vim
#   emacs

  # git
    git
    git-crypt
    git-lfs

  # python
    python3
    python3-pip
    python3-venv

  # vm
    qemu-system
    qemu-kvm
    libvirt-daemon-system
    libvirt-daemon
    virtinst
    virt-manager
    bridge-utils
    libosinfo-bin
#   virtualbox-7.2

  # container
    podman
    containerd

  # k8s
    kubectl
#   kubelet
#   kubeadm

  # locale
