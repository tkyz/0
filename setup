        arr+=('firmware-linux')
        arr+=('firmware-realtek')
        arr+=('firmware-iwlwifi')
      fi

      # vol
      if ! is_container; then
        arr+=('parted')
        arr+=('cryptsetup')
        arr+=('lvm2')
      fi

      # fuse
      arr+=('fuse')
      arr+=('archivemount')
      arr+=('cifs-utils')
      arr+=('gocryptfs')

      # gpu
      arr+=('nvidia-container-toolkit')
      if ! is_container; then
        arr+=('nvidia-kernel-dkms')
        arr+=('nvidia-driver')
        arr+=('nvidia-detect')
        arr+=('nvidia-smi')
      fi

      # archive
      arr+=('libarchive-tools')
      arr+=('unar')
      arr+=('zip')

      # print
      arr+=('cups')

      # git
      arr+=('git')
      arr+=('git-crypt')
      arr+=('git-lfs')

      # python
      arr+=('python3')
      arr+=('python3-pip')
      arr+=('python3-venv')

      # vm
      if ! is_container; then
        arr+=('qemu-system')
        arr+=('qemu-kvm')
        arr+=('libvirt-daemon-system')
        arr+=('libvirt-daemon')
        arr+=('virtinst')
        arr+=('virt-manager')
