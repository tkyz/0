#!/bin/bash
: << 'END_OF_BATCH'
@rem ================================ windows batch [ms932, crlf] ================================
@echo off
setlocal

  cd /d "%USERPROFILE%"

  set dist=debian

  wsl --unregister %dist%
  wsl --set-default-version 2
  wsl --install --distribution %dist%

  wsl --terminate    %dist%
  wsl --set-version  %dist% 2
  wsl --distribution %dist% -- sed -i 's#:/root:#:/mnt/c/Users/%USERNAME%:#' /etc/passwd
  wsl --distribution %dist% -- $^(wslpath -u %~0^)
  wsl --terminate    %dist%

endlocal
exit /b
END_OF_BATCH
# ================================ linux shell script [utf8, lf] ================================
set -o errexit
set -o nounset
set -o pipefail

source /etc/os-release
test 'debian' == "${ID_LIKE:-${ID}}"
test 'bash'   == "${SHELL##*/}"

readonly unix_epoch='1970-01-01 00:00:00'
readonly arch="$(dpkg --print-architecture)"
readonly user="${USER:-root}"
readonly home="${HOME:-/root}"
readonly ppwd="${PWD}"

readonly external_ip="$(type -p ip &> /dev/null && ip a | grep inet | grep -v inet6 | grep 'scope global' | awk -F ' ' '{print $2}' | sed 's|/.*||g' | sort | head -n 1 || true)"
readonly resolve="$(cat /etc/resolv.conf | grep ^nameserver | head -n 1 | cut -d ' ' -f 2)"

# env
if true; then

  readonly tag="${tag:-latest}"
  readonly context="${context:-${tag}}"
  readonly tld="${tld:-$(hostname -f)}"

  readonly github_user="${github_user:-${user}}"

fi

# envsubst
function env_replace() {
  (
    sed \
      -e "s|\${HOME}|${home}|g" \
      -e "s|\${external_ip}|${external_ip}|g" \
      -e "s|\${resolve}|${resolve}|g" \
      -e "s|\${tag}|${tag}|g" \
      -e "s|\${tld}|${tld}|g"
  )
}

function keys() {
  {
    echo '0000000000000000000000000000000000000000'
    echo '00000000-0000-0000-0000-000000000000'
    echo "${openpgp4fpr}"
    gpg --with-colons --list-secret-keys | grep -A 1 ^sec: | grep ^fpr: | cut -d ':' -f 10
    gpg --with-colons --list-keys        | grep -A 1 ^pub: | grep ^fpr: | cut -d ':' -f 10
    lsblk --all --fs --paths --json | jq -cr '.. | objects | .uuid | select(. != null)'
    find './src/0.fpr' -mindepth 1 -maxdepth 1 -type d | sed 's#.*/##g' 2> /dev/null || true
  } | sort -u
}

#----------------------------------------------------------------
# is_...

function is_sudoer() {
  if unset SUDO 2> /dev/null; then
    if [[ '0' == "$(id -u)" ]]; then
      readonly SUDO=
    elif type sudo &> /dev/null && sudo -v -n > /dev/null; then
      readonly SUDO=sudo
    else
      sudo -k
      false
    fi
  fi
}

function is_deb() {
# test 'debian' == "${ID_LIKE}" ||
  test 'debian' == "${ID}"
} &> /dev/null

function is_container() {
  test 'podman' == "${container:-}" ||
  test -f '/run/.containerenv' ||
  test -f '/.dockerenv' ||
  test "$(cat '/proc/1/cgroup')" == '0::/' ||
  test "$(cat '/proc/1/cgroup')" == '0::/system.slice/containerd.service'
} &> /dev/null

function is_k8s() {
  test -v KUBERNETES_PORT
} &> /dev/null

function is_wsl() {
  test -v WSLENV &&
  type wslpath
} &> /dev/null

function is_x11() {
  test -v DISPLAY
} &> /dev/null

function is_ssh() {
  test -v SSH_CONNECTION
} &> /dev/null

function is_cmd() {
  test 'file' == "$(type -t "${1}" || ${SUDO} bash -c "type -t '${1}'" || true)"
} &> /dev/null

function is_func() {
  test 'function' == "$(type -t "${1}" || true)"
} &> /dev/null

function is_tcp() {
  timeout 1 bash -c "cat /dev/null > /dev/tcp/${1}/${2}"
} &> /dev/null

