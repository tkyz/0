readonly resolve="$(cat /etc/resolv.conf | grep ^nameserver | head -n 1 | cut -d ' ' -f 2)"
readonly tld="$(cat "${HOME}/.tld" 2> /dev/null || hostname -d)"
readonly setup_yml="$(cat << EOS
