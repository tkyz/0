        arr+=('libosinfo-bin')
      fi

      # container
      if ! is_container; then
        arr+=('podman')
        arr+=('containerd.io')
      fi

      # k8s
#     arr+=('kubeadm')
#     arr+=('kubelet')
      arr+=('kubectl')

      # locale
      arr+=('locales-all')
      arr+=('task-japanese')
      arr+=('fonts-dejavu-core')

      arr+=('util-linux')
      arr+=('procps')
      arr+=('uuid-runtime')
      arr+=('faketime')
      arr+=('openssl')
      arr+=('openssh-client')
      arr+=('openssh-server')
      arr+=('pkg-config')
      arr+=('gettext-base')

      if ! is_container; then
        arr+=('ufw')
        arr+=('rkhunter')
        arr+=('clamav')
      fi

      arr+=('rsync')
      arr+=('xsel')
      arr+=('parallel')
      arr+=('nkf')
      arr+=('jq')
      arr+=('htop')
      arr+=('tmux')
      arr+=('qrencode')

      arr+=('vim')
#     arr+=('emacs')

      arr+=('nmap')
      arr+=('tcpdump')

      arr+=('moreutils')
      arr+=('aria2')
      arr+=('ffmpeg')
      arr+=('webp-pixbuf-loader')
      arr+=('libcairo2')
      arr+=('build-essential')
