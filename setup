    arr+=('libcairo2')
    arr+=('build-essential')
    arr+=('libglfw3-dev')
    arr+=('libgles2-mesa-dev')
    arr+=('libcairo2-dev')
    arr+=('virt-manager')
#   arr+=('winehq-stable')
    # k8s
#   arr+=('kubeadm')
#   arr+=('kubelet')
    arr+=('kubectl')
    # gpu
    arr+=('nvidia-container-toolkit')
    if ! is_container; then
      arr+=('nvidia-kernel-dkms')
      arr+=('nvidia-driver')
      arr+=('nvidia-detect')
      arr+=('nvidia-smi')
    fi

    ${SUDO} apt-get update
    ${SUDO} apt-get install -y "${arr[@]}"

  )

}

function _venv() {
  (

    venv_dir='./.venv'

    python3 -m venv "${venv_dir}"

    if ! is_func 'deactivate'; then
      source "${venv_dir}/bin/activate"
    fi

    req_file="${venv_dir}/requirements.txt"
    tmp_file="${req_file}.tmp"
    {
      echo pip
      echo yq
      touch "${req_file}" && cat "${req_file}"
      pip freeze | sed -e 's/[!=<> #].*//g'
    } 2> /dev/null | sort -u > "${tmp_file}"
    mv "${tmp_file}" "${req_file}"

    pip install --upgrade --requirement "${req_file}"

  )
}

function _mnt() {
  (

    mnt_key="${1:-}"
    mnt_dir="${2:-./mnt/${mnt_key}}"

    # list...
    if [[ -z "${mnt_key}" || -z "${mnt_dir}" ]]; then
      keys | while read key; do
        _mnt "${key}"
      done
      return
    fi

    # skip
    if mountpoint "${mnt_dir}" &> /dev/null; then
      return
    fi

    base_dir="./src/0.fpr/${mnt_key}"
    mkdir -p "${base_dir}"

    enc_dir="${base_dir}/enc"
    gpw_file="${base_dir}/gpw"

    # uuid
    if [[ "${mnt_key}" =~ ^[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{12}$ ]] && is_sudoer; then

      uuid="${mnt_key}"
      blk_info="$(lsblk --all --fs --json --paths | jq -cr ".. | objects | select(.uuid == \"${uuid}\")")"
      name="$(  echo "${blk_info}" | jq -cr '.name')"
      fstype="$(echo "${blk_info}" | jq -cr '.fstype')"

      if [[ 'crypto_LUKS' == "${fstype}" ]]; then
 
        if [[ ! -f "${gpw_file}" ]]; then
          return
        fi

        map_dir="/dev/mapper/${uuid}"
        if [[ -e "${map_dir}" ]]; then
          return
        fi

        gpg --decrypt "${gpw_file}" | ${SUDO} cryptsetup open --type luks "${name}" "${uuid}" || true

      elif [[ -n "${fstype}" ]]; then

        mnt_opts=''
#       mnt_opts+=',file_mode=0600'
#       mnt_opts+=',dir_mode=0700'
#       mnt_opts+=",uid=$(id -u)"
#       mnt_opts+=",gid=$(id -g)"

        mkdir -p "${mnt_dir}"
        ${SUDO} mount --options "${mnt_opts}" UUID="${uuid}" "${mnt_dir}" || rm -d "${mnt_dir}"

      fi

    # fpr
    elif [[ "${mnt_key}" =~ ^[0-9a-fA-F]{40}$ ]]; then

      mkdir -p \
        "${enc_dir}" \
        "${mnt_dir}"

      # init
      conf_file_org="${enc_dir}/gocryptfs.conf"
      conf_file_gpg="${conf_file_org}.gpg"
      test ! -f "${gpw_file}"                                      && cat /dev/urandom | tr --complement --delete '[:graph:]' | head -c 2048 | gpg --encrypt --throw-keyids > "${gpw_file}"      || true
      test ! -f "${conf_file_org}" &&   test -f "${conf_file_gpg}" && cat "${conf_file_gpg}"                                                 | gpg --decrypt                > "${conf_file_org}" || true
      test ! -f "${conf_file_org}" && ! test -f "${conf_file_gpg}" && gocryptfs -extpass 'gpg' -extpass '--decrypt' -extpass "${gpw_file}" -init "${enc_dir}"
      test   -f "${conf_file_org}" && ! test -f "${conf_file_gpg}" && cat "${conf_file_org}"                                                 | gpg --encrypt --throw-keyids > "${conf_file_gpg}" || true

      gocryptfs \
        -extpass 'gpg' \
        -extpass '--decrypt' \
        -extpass "${gpw_file}" \
        "${enc_dir}" \
        "${mnt_dir}" || rm -d "${mnt_dir}"

    fi

  )
}

function _umnt() {
  (

    mnt_key="${1:-}"
    mnt_dir="./mnt/${mnt_key}"

    # list...
    if [[ -z "${mnt_key}" ]]; then
      keys | while read key; do
        _umnt "${key}"
      done
      return
    fi

    # skip
    if ! mountpoint "${mnt_dir}" &> /dev/null; then
      return
    fi

    # uuid
    if [[ "${mnt_key}" =~ ^[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{12}$ ]] && is_sudoer; then

      uuid="${mnt_key}"
      blk_info="$(lsblk --all --fs --json --paths | jq -cr ".. | objects | select(.uuid == \"${uuid}\")")"
      fstype="$(echo "${blk_info}" | jq -cr '.fstype')"

      if [[ 'crypto_LUKS' == "${fstype}" ]]; then
        ${SUDO} cryptsetup close "${uuid}" || true

      else
        ${SUDO} fusermount -u "${mnt_dir}" && rm -d "${mnt_dir}" || true
      fi

    # fpr
    elif [[ "${mnt_key}" =~ ^[0-9a-fA-F]{40}$ ]]; then
      fusermount -u "${mnt_dir}" && rm -d "${mnt_dir}" || true
    fi

  )
}

function _k8s() {
  (
    if ! is_wsl && ! is_container && is_sudoer && is_cmd kind && is_cmd kubectl; then

      kind delete cluster --name "${context}" || true

      ${SUDO} sysctl --write fs.inotify.max_user_instances=1024     #  128
      ${SUDO} sysctl --write fs.inotify.max_user_watches=65536      # 8192
      ${SUDO} sysctl --write net.ipv4.ip_unprivileged_port_start=53 # 1024
      cat './src/0.kind/kind.yml' | env_replace | KIND_EXPERIMENTAL_PROVIDER=podman kind create cluster --name "${context}" --config -
      ${SUDO} sysctl --write net.ipv4.ip_unprivileged_port_start=1024

      kubectl config set-context     "kind-${context}"
      kubectl cluster-info --context "kind-${context}"

      kubectl get configmap kube-proxy --namespace kube-system --output yaml | sed 's/strictARP: false/strictARP: true/' | kubectl apply -f -

      # loadbalancer
#     cat  './src/com.github/metallb/metallb/config/manifests/metallb-native.yaml'                          | kubectl apply -f -
      curl 'https://raw.githubusercontent.com/metallb/metallb/v0.14.9/config/manifests/metallb-native.yaml' | kubectl apply -f -

      # ingress
#     cat  './src/com.github/kubernetes/ingress-nginx/deploy/static/provider/kind/deploy.yaml'                                     | kubectl apply -f -
      curl 'https://raw.githubusercontent.com/kubernetes/ingress-nginx/controller-v1.12.0/deploy/static/provider/kind/deploy.yaml' | kubectl apply -f -

      # dashboard
#     cat  './src/com.github/kubernetes/dashboard/aio/deploy/recommended.yaml'                         | kubectl apply -f -
      curl 'https://raw.githubusercontent.com/kubernetes/dashboard/v2.7.0/aio/deploy/recommended.yaml' | kubectl apply -f -

      kubectl delete namespace 0 2> /dev/null || true
      kubectl create namespace 0              || true

    fi
  )
}

function _validate() {
  (
    git grep --cached -n \
      -e "${openpgp4fpr}"                        --or \
      -e "${external_ip}"                        --or \
      -e "${user}"                               --or \
      -e "${home}"                               --or \
      -e '-----BEGIN PGP PRIVATE KEY BLOCK-----' --or \
      -e '-----BEGIN OPENSSH PRIVATE KEY-----'   --or \
      -e '-----BEGIN RSA PRIVATE KEY-----'       --or \
      -e 'TODO:' || true
  )
}

function _build() {
  (

    src_key="${1:-}"

    if [[ -z "${src_key}" ]]; then
      find './src' -name 'Makefile' -or -name 'build.xml' -or -name 'pom.xml' -or -name 'package.json' -or -name 'Dockerfile' | while read item; do
        _build "$(echo "${item}" | sed -r 's|^\./src/(.*)/[^/]+$|\1|g')"
      done
      return
    fi

    [[ "${src_key}" =~ ^com\.github/.*$   ]] && return || true
    [[ "${src_key}" =~ ^com\.gitlab/.*$   ]] && return || true
    [[ "${src_key}" =~ ^org\.golang/.*$   ]] && return || true
    [[ "${src_key}" =~ ^0\.playground/.*$ ]] && return || true

    pushd "./src/${src_key}" &> /dev/null

      echo '---'
      pwd

      if [[ -f './Makefile' ]]; then
        true
      fi

      if [[ -f './build.xml' ]]; then
        true
      fi
      if [[ -f './pom.xml' ]]; then

        MAVEN_OPTS='-Xms256m -Xmx256m -XX:-UsePerfData'

        opts=()
        opts+=('--threads' '1C')
        opts+=('--define'  "version=${tag}")
        opts+=('--define'  'checkstyle.skip=false')
        opts+=('--define'  'maven.test.skip=false')
        opts+=('--define'  'maven.javadoc.skip=false')
        opts+=('--define'  'assembly.skipAssembly=true')

        mvn "${opts[@]}" clean package # deploy

      fi

      if [[ -f './package.json' ]]; then
        true
#       npm install
#       npm run build
      fi

      if [[ -f './Dockerfile' ]]; then

        image="container.0/${src_key}:${tag}"
        if [[ -z "$(podman images --noheading "${image}")" ]]; then

          opts=()
          opts+=('--tag' "${image}")
          opts+=('--pull')
#         opts+=('--no-cache')

          podman build "${opts[@]}" .
#         if ping -c 1 -W 3 'container.0' &> /dev/null; then
#           podman push --tls-verify=false "${image}" || true
#         fi

        fi

      fi

    popd &> /dev/null

  )
}

function _deploy() {
  (

    src_key="${1:-}"

    if [[ -z "${src_key}" ]]; then
      find './src' -name 'deploy.yml' | while read item; do
        _deploy "$(echo "${item}" | sed -r 's|^\./src/(.*)/[^/]+$|\1|g')"
      done
      return
    fi

    test ! -f "./src/${src_key}/deploy.yml" && return || true

    pushd "./src/${src_key}" &> /dev/null

      echo '---'
      pwd

      yq -cr '.. | objects | select(.image != null) | .image' deploy.yml | env_replace | while read image; do

        if [[ -z "$(podman images --noheading "${image}")" ]]; then
          continue
        fi
        if podman exec "${context}-control-plane" crictl images | awk -F ' ' '{print $1":"$2}' | grep -q "${image}"; then
          continue
        fi

        tmpfile="$(mktemp)"
        podman save --format oci-archive "${image}" --output "${tmpfile}"
        kind load image-archive --name "${context}" "${tmpfile}" || true
        rm "${tmpfile}"

      done

      cat './deploy.yml' | env_replace | kubectl apply -f -

    popd &> /dev/null

  )
}

function _clean() {

  if is_sudoer; then
    ${SUDO} apt-get autoremove -y
    ${SUDO} apt-get clean
  fi

  if is_cmd podman; then
    podman system  prune --force || true
    podman volume  prune --force || true
    podman network prune --force || true
  fi
  if is_cmd docker; then
    docker system  prune --force || true
    docker volume  prune --force || true
    docker network prune --force || true
  fi
  if is_cmd pip3; then
    pip3 cache purge
  fi

}

function _sandbox() {
  (

    image="${ID}:${VERSION_CODENAME:-latest}"

    uuid="$(uuidgen)"
    opts=()
    opts+=('--interactive')
    opts+=('--tty')
    opts+=('--rm')
    opts+=('--name'    "0.sandbox.${uuid}")
#   opts+=('--network' 'host')
#   opts+=('--env'     "UID=$(id -u)")
    # cache
    opts+=('--volume'  './.cache/pip:/root/.cache/pip')
    opts+=('--volume'  './.m2:/root/.m2')
    # x11
    opts+=('--env'     "DISPLAY=${DISPLAY:-:0.0}")
    opts+=('--volume'  '/tmp/.X11-unix/X0:/tmp/.X11-unix/X0')
    # home
    opts+=('--volume'  './.local/bin:/root/.local/bin:ro')
    opts+=('--volume'  './.profile:/root/.profile:ro')
    opts+=('--volume'  './.bashrc:/root/.bashrc:ro')
    opts+=('--volume'  './setup:/root/setup:ro')
    opts+=('--volume'  './bin:/root/bin:ro')
    opts+=('--volume'  './doc:/root/doc:ro')
    opts+=('--volume'  './lib:/root/lib:ro')
    opts+=('--volume'  './opt:/root/opt:ro')
    opts+=('--volume'  './src:/root/src:ro')
#   opts+=('--volume'  './mnt/0.dfs:/root/mnt/0.dfs:ro')
    # workdir
    opts+=('--volume'  "./tmp:/root/src/0.fpr")
    opts+=('--volume'  './tmp:/root/tmp')
    opts+=('--volume'  "${ppwd}:/root/.${uuid}")
    opts+=('--workdir'         "/root/.${uuid}")
    # enc
    opts+=('--device'  '/dev/fuse')
    opts+=('--cap-add' 'SYS_ADMIN')

    podman run "${opts[@]}" "${image}"
#   kubectl -n 0 run -it --rm --image="${image}" -- bash

  )
}

function _browse() {

  if ! is_x11; then
    return
  fi

  cat << EOS | python3 &
from selenium                           import webdriver
from selenium.webdriver.firefox.options import Options

def main():

  opts = Options()
  opts.set_preference('general.useragent.override',    'Mozilla/5.0')
  opts.set_preference('browser.cache.memory.enable',   True)
  opts.set_preference('browser.cache.disk.enable',     False)
  opts.set_preference('browser.tabs.animate',          False)
  opts.set_preference('browser.panorama.animate_zoom', False)
  opts.set_preference('geo.enabled',                   False)

  driver = webdriver.Firefox(opts)
  driver.maximize_window();
  driver.get('${1}')

if __name__ == '__main__':
  main()
EOS

}

function _llm() {
  (

    if [[ -n "${1:-}" ]]; then
      echo "${@}" | _llm
      return
    fi

    script_file="$(mktemp)"
    cat << EOS > "${script_file}"
import os
import sys
import re
import time
import regex
import torch
from transformers import (
  AutoTokenizer,
  AutoModelForCausalLM,
  TextStreamer,
  Trainer,
  TrainingArguments,
  DataCollatorForLanguageModeling,
)
from datasets import Dataset

token_file = './doc/token.txt'
model_path = './lib/0.llm/7b'
if not os.path.isdir(model_path):
  # find './lib' -type f -name 'tokenizer.*' 2> /dev/null | dirname | sort -u
  model_path = './lib/co.huggingface/stabilityai/japanese-stablelm-base-gamma-7b'

def gen(tokenizer, model, prompt, max=4096):

  embed_tokens(tokenizer, model, prompt)

  streamer   = TextStreamer(tokenizer, skip_prompt=True, skip_special_tokens=True)
  input_ids  = tokenizer.encode(prompt, add_special_tokens=False, return_tensors='pt')
  output_ids = model.generate(input_ids.to(device=model.device), max_new_tokens=max, temperature=1.0, top_p=1.0, do_sample=True, streamer=streamer)

# print(tokenizer.convert_ids_to_tokens(input_ids[0]))
# print(tokenizer.convert_ids_to_tokens(output_ids[0]))
# embed_tokens(tokenizer, model, tokenizer.decode(input_ids[0]))
  embed_tokens(tokenizer, model, tokenizer.decode(output_ids[0]))

def embed_tokens(tokenizer, model, prompt):

  with open('./setup', 'r', encoding="UTF-8") as f:
    source = f.read()

  tokens = set()
  if os.path.isfile(token_file):
    with open(token_file, 'r', encoding="UTF-8") as f:
      tokens |= set(f.read().splitlines())
  tokens |= set(regex.findall(r'\X', source))
  tokens |= set(regex.findall(r'\X', prompt))
  tokens  = map(lambda s: s.strip(), tokens)
  tokens  = filter(lambda s: '' != s, tokens)
  tokens  = set(tokens)
  tokens  = list(tokens)
  tokens  = sorted(tokens)
  tokens  = sorted(tokens, key=len, reverse=True)

  lines = map(lambda s: s + '\n', tokens)
  lines = list(lines)
  with open(token_file, 'w', encoding="UTF-8") as f:
    f.writelines(lines)

  embed  = set()
  embed |= {os.environ.get('openpgp4fpr')}
  embed |= {' ', '\t', '\r', '\n'}
  embed |= set(tokens)
  embed |= remaind_tokens(embed, source)
# embed |= remaind_tokens(embed, prompt)
  # find './doc/ref' -type d -name '*.txt' 2> /dev/null
  embed  = list(embed)

  vocab_len = len(tokenizer.get_vocab())
  if 0 < tokenizer.add_tokens(embed):
    model.resize_token_embeddings(len(tokenizer), mean_resizing=True)

def remaind_tokens(tokens, text):

  tokens = list(tokens)
  tokens = filter(lambda s: 1 < len(s), tokens)
  tokens = sorted(tokens, key=len, reverse=True)
  tokens.insert(0, r'[\s\t\r\n\+\-\*/=%_\.:,;\"\'\^\~\(\)\[\]\{\}<>\`\?$&\|#@!\\\\、。！？：；（）「」＜＞＿]+')

  i = 0
  queue = [text]
  while i < len(queue):

    item = queue[i]

    cnt = 0
    for j, token in enumerate(tokens):

      if 0 == j:
        items = re.split(token, item)
      else:
        items = item.split(token)

      cnt = len(items)

      if 0 == cnt:
        queue.pop(i)
        break

      if 1 < cnt:
        queue.pop(i)
        queue += items
        break

    if 1 == cnt:
      i += 1

  return set(queue)

def main():

  tokenizer = AutoTokenizer.from_pretrained(model_path)
  model     = AutoModelForCausalLM.from_pretrained(model_path, torch_dtype='auto', device_map='auto', local_files_only=True)

  while True:

    prompt = sys.stdin.readline()
    if '' == prompt:
      break

    try:
      gen(tokenizer, model, prompt)
    except KeyboardInterrupt as e:
      print(e)
      continue

    # train
    if False:

      def tokenize_function(dataset):
        return tokenizer(dataset["text"], truncation=True) # max_length=tokenizer.model_max_length

      dataset           = Dataset.from_list([{"text": prompt}])
      tokenized_dataset = dataset.map(tokenize_function, batched=False)
      data_collator     = DataCollatorForLanguageModeling(tokenizer=tokenizer, mlm=False)

  # save
# tokenizer.save_pretrained(model)
# model.save_pretrained(model)

if __name__ == '__main__':
  main()
EOS
    python3 "${script_file}" 2> /dev/null || true

    rm "${script_file}"

  )
}

#----------------------------------------------------------------
# main

function main() {
  (
    pushd "${home}" &> /dev/null

      arg1=''
      if [[ "${BASH_SOURCE:-}" =~ ^.*/fpr$ ]]; then
        arg1="${1:-}"
        shift || true
      fi

      # .fprrc
      if [[ -z "${arg1}" ]] && ! mountpoint './fpr' &> /dev/null; then

        _deps
        _fpr
#       _mnt
        _mnt "${openpgp4fpr}" './fpr'
        _home
        _license
        chmod    go-rwx '.'        &> /dev/null || true
        chmod -R go-rwx './.gnupg' &> /dev/null || true
        chmod -R go-rwx './.ssh'   &> /dev/null || true
#       find './src/0.fpr' -type f | xargs --no-run-if-empty chmod 600 || true
#       find './src/0.fpr' -type d | xargs --no-run-if-empty chmod 700 || true

        _apt
        _venv

        main .
        main -
        _k8s
        main ci
        main cd

      fi
      _fpr

      if ! is_func 'deactivate'; then
        source './.venv/bin/activate'
      fi

      # handle
      if [[ -z "${arg1}" ]]; then
        true

      elif [[ '.' == "${arg1}" ]]; then

        echo    "openpgp4fpr:${openpgp4fpr}"
        echo -n "openpgp4fpr:${openpgp4fpr}" | qrencode --type ansi

#       gpg --with-colons --list-secret-keys | grep -A 1 ^sec: | grep ^fpr: | cut -d ':' -f 10 | while read fpr; do gpg --export-secret-keys         "0x${fpr}" > "./${fpr}.key";           done
        gpg --with-colons --list-keys        | grep -A 1 ^pub: | grep ^fpr: | cut -d ':' -f 10 | while read fpr; do gpg --export             --armor "0x${fpr}" > "./src/0.fpr/${fpr}/pub"; done

        gpg --export --armor "0x${openpgp4fpr}"                              > './doc/pub'
        gpg --export --armor "0x${openpgp4fpr}" | qrencode --type svg --output './doc/pub.svg'
        echo -n "http://doc.${tld}/"            | qrencode --type png --output './doc/logo.png'
#       _browse "http://doc.${tld}/"

      elif [[ '-' == "${arg1}" ]]; then
        kind delete clusters --all
        _umnt
        _clean

      elif [[ 'ci' == "${arg1}" ]]; then
        _validate
        _build

      elif [[ 'cd' == "${arg1}" ]]; then
        _deploy

      elif is_func "_${arg1}"; then
        "_${arg1}" "${@}"

      elif is_cmd wine && [[ -f "${arg1}" && "${arg1}" =~ ^.*\.exe$ ]]; then
        wine "${arg1}" "${@}"
      fi

    popd &> /dev/null
  )
}
main "${@}"
