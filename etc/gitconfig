[init]
	defaultBranch = main
[core]
	ignorecase = false
	quotepath = false
	autocrlf = false
	safecrlf = true
	filemode = true
[gpg]
	program = /usr/bin/gpg
[commit]
	gpgsign = true
[color]
	ui = auto
	diff = auto
	status = auto
	branch = auto
[merge]
	ff = false
[pull]
	ff = only
	rebase = true
[diff "sjis"]
	textconv = iconv -f sjis
[alias]
	graph = log --all --graph --pretty=format:\"<%H> %ad [%an] %cd [%cn] %G? %Cgreen%d%Creset %s\" --date=short --date-order
