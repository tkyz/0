#!/bin/bash

if [[ ! -v openpgp4fpr ]]; then

  machine_id="$(cat '/etc/machine-id'                 || printf '%032d')"
  boot_id="$(   cat '/proc/sys/kernel/random/boot_id' || printf '%08d-%04d-%04d-%04d-%012d')"
  openpgp4fpr="$(openpgp4fpr)"
  tag='latest'

  domain="$(hostname -d)"
  namespace="$(echo "${domain}" | tr '.' $'\n' | tac | paste -s -d '.')"
  host="$(hostname)"
# fqdn="$(hostname -f)"

  user="${USER:-root}"
  home="${HOME:-/root}"

  if is_sudoer; then
    if [[ '0' == "$(id -u)" ]]; then
      SUDO=
    elif type sudo &> /dev/null && sudo -v -n > /dev/null; then
      SUDO='sudo '
    fi
  fi

  if ! is_venv; then
    source "${home}/.venv/bin/activate"
  fi

fi
