#!/bin/bash

set -o errexit
set -o nounset
set -o pipefail

(

  if ! is_container; then

    if is_sudoer; then
      sudo nvidia-ctk cdi generate --output='/etc/cdi/nvidia.yaml'
    fi

    uuid="$(uuidgen)"
    image='python:3.11'

    opts=()
    opts+=('--interactive')
    opts+=('--tty')
    opts+=('--rm')
    opts+=('--name'       "${uuid}")
    opts+=('--hostname'   "${uuid}")
    opts+=('--device'     'nvidia.com/gpu=all')
    opts+=('--publish'    '8188:8188')
    opts+=('--entrypoint' 'bash')
    opts+=('--workdir'    "/${uuid}")

    opts+=('--volume'     "$(printf '%s:%s'    "${HOME}/.cache/pip"                                                                                     '/root/.cache/pip')")
    opts+=('--volume'     "$(printf '%s:%s:ro' "${HOME}/bin/is_container"                                                                               '/usr/local/bin/is_container')")
    opts+=('--volume'     "$(printf '%s:%s:ro' "${BASH_SOURCE}"                                                                                         '/entrypoint')")

    opts+=('--volume'     "$(printf "%s:%s"    "${HOME}/src/com.github/comfyanonymous/ComfyUI"                                                          "/${uuid}")")
#   opts+=('--volume'     "$(printf "%s:%s"    "${HOME}/src/com.github/ltdrdata/ComfyUI-Manager"                                                        "/${uuid}/custom_nodes/ComfyUI-Manager")")
    opts+=('--volume'     "$(printf "%s:%s"    "${HOME}/src/com.github/cubiq/ComfyUI_IPAdapter_plus"                                                    "/${uuid}/custom_nodes/ComfyUI_IPAdapter_plus")")

    type='checkpoints'
    opts+=('--volume'     "$(printf '%s:%s:ro' "${HOME}/lib/co.huggingface/stabilityai/stable-diffusion-xl-base-1.0/sd_xl_base_1.0.safetensors"         "/${uuid}/models/${type}/co.huggingface/stabilityai/stable-diffusion-xl-base-1.0/sd_xl_base_1.0.safetensors")")
#   opts+=('--volume'     "$(printf '%s:%s:ro' "${HOME}/lib/co.huggingface/stabilityai/stable-diffusion-xl-refiner-1.0/sd_xl_refiner_1.0.safetensors"   "/${uuid}/models/${type}/co.huggingface/stabilityai/stable-diffusion-xl-refiner-1.0/sd_xl_refiner_1.0.safetensors")")
    opts+=('--volume'     "$(printf '%s:%s:ro' "${HOME}/lib/com.civitai/models"                                                                         "/${uuid}/models/${type}/com.civitai")")

    type='controlnet'
#   opts+=('--volume'     "$(printf '%s:%s:ro' "${HOME}/lib/co.huggingface/comfyanonymous/ControlNet-v1-1_fp16_safetensors"                             "/${uuid}/models/${type}/co.huggingface/comfyanonymous/ControlNet-v1-1_fp16_safetensors")")

    type='clip_vision'
    opts+=('--volume'     "$(printf '%s:%s:ro' "${HOME}/lib/co.huggingface/h94/IP-Adapter/sdxl_models/image_encoder/model.safetensors"                  "/${uuid}/models/${type}/CLIP-ViT-bigG-14-laion2B-39B-b160k.safetensors")")

    type='ipadapter'
    opts+=('--volume'     "$(printf '%s:%s:ro' "${HOME}/lib/co.huggingface/h94/IP-Adapter/sdxl_models/ip-adapter_sdxl.safetensors"                      "/${uuid}/models/${type}/co.huggingface/h94/IP-Adapter/ip-adapter_sdxl.safetensors")")
    opts+=('--volume'     "$(printf '%s:%s:ro' "${HOME}/lib/co.huggingface/h94/IP-Adapter/sdxl_models/ip-adapter_sdxl_vit-h.safetensors"                "/${uuid}/models/${type}/co.huggingface/h94/IP-Adapter/ip-adapter_sdxl_vit-h.safetensors")")
    opts+=('--volume'     "$(printf '%s:%s:ro' "${HOME}/lib/co.huggingface/h94/IP-Adapter/sdxl_models/ip-adapter-plus_sdxl_vit-h.safetensors"           "/${uuid}/models/${type}/co.huggingface/h94/IP-Adapter/ip-adapter-plus_sdxl_vit-h.safetensors")")
    opts+=('--volume'     "$(printf '%s:%s:ro' "${HOME}/lib/co.huggingface/h94/IP-Adapter/sdxl_models/ip-adapter-plus-face_sdxl_vit-h.safetensors"      "/${uuid}/models/${type}/co.huggingface/h94/IP-Adapter/ip-adapter-plus-face_sdxl_vit-h.safetensors")")
    opts+=('--volume'     "$(printf '%s:%s:ro' "${HOME}/lib/co.huggingface/h94/IP-Adapter-FaceID/ip-adapter-faceid_sdxl.bin"                            "/${uuid}/models/${type}/co.huggingface/h94/IP-Adapter-FaceID/ip-adapter-faceid_sdxl.bin")")
    opts+=('--volume'     "$(printf '%s:%s:ro' "${HOME}/lib/co.huggingface/h94/IP-Adapter-FaceID/ip-adapter-faceid-plusv2_sdxl.bin"                     "/${uuid}/models/${type}/co.huggingface/h94/IP-Adapter-FaceID/ip-adapter-faceid-plusv2_sdxl.bin")")
    opts+=('--volume'     "$(printf '%s:%s:ro' "${HOME}/lib/co.huggingface/h94/IP-Adapter-FaceID/ip-adapter-faceid-portrait_sdxl.bin"                   "/${uuid}/models/${type}/co.huggingface/h94/IP-Adapter-FaceID/ip-adapter-faceid-portrait_sdxl.bin")")
    opts+=('--volume'     "$(printf '%s:%s:ro' "${HOME}/lib/co.huggingface/h94/IP-Adapter-FaceID/ip-adapter-faceid-portrait_sdxl_unnorm.bin"            "/${uuid}/models/${type}/co.huggingface/h94/IP-Adapter-FaceID/ip-adapter-faceid-portrait_sdxl_unnorm.bin")")

    type='loras'
    opts+=('--volume'     "$(printf '%s:%s:ro' "${HOME}/lib/co.huggingface/h94/IP-Adapter-FaceID/ip-adapter-faceid_sdxl_lora.safetensors"               "/${uuid}/models/${type}/co.huggingface/h94/IP-Adapter-FaceID/ip-adapter-faceid_sdxl_lora.safetensors")")
    opts+=('--volume'     "$(printf '%s:%s:ro' "${HOME}/lib/co.huggingface/h94/IP-Adapter-FaceID/ip-adapter-faceid-plusv2_sdxl_lora.safetensors"        "/${uuid}/models/${type}/co.huggingface/h94/IP-Adapter-FaceID/ip-adapter-faceid-plusv2_sdxl_lora.safetensors")")

    type='insightface'
    # https://github.com/deepinsight/insightface/releases/download/v0.7/buffalo_l.zip

    podman run "${opts[@]}" "${image}" '/entrypoint'

#   kubectl -n "$(hostname)" run -it --rm --image="${image}" -- bash

  else

#   pip install --upgrade pip
    cat << EOS | sort -u | pip install --requirement '/dev/stdin'
$(cat 'requirements.txt')
pillow
insightface
onnxruntime
onnxruntime-gpu
EOS

    python main.py --listen

  fi

)
