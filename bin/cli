#!/usr/bin/env python3

import os
import sys
import re
import subprocess

home    = os.environ.get('HOME')
bin_dir = home + '/bin'

def main():

  name = re.sub(r'^.*/', r'', sys.argv[0])
  args = sys.argv[1:]

  subcommand         = None
  subcommand_args    = []
  subcommand_end_idx = len(args)

  for i, arg in enumerate(args):
    if arg.startswith('-'):
      subcommand_end_idx = i
      break

  for i in range(subcommand_end_idx, 0, -1):

    subcommand_name = name + '-' + '-'.join(args[:i])
    subcommand_path = bin_dir + '/' + subcommand_name

    if not os.path.isfile(subcommand_path):
      continue

    subcommand      = subcommand_path
    subcommand_args = args[i:]
    break

  if not subcommand:
    for f in sorted(os.listdir(bin_dir)):
      if f.startswith(name):
        print(f)
    sys.exit(1)

  try:

    result = subprocess.run(
      [subcommand] + subcommand_args,
      stdin  = sys.stdin,
      stdout = sys.stdout,
      stderr = sys.stderr
    )

    sys.exit(result.returncode)

  except Exception as e:
    print(e, file=sys.stderr)
    sys.exit(1)

if __name__ == '__main__':
  main()
