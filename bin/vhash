#!/usr/bin/env python3

import sys
import hashlib
import subprocess

def exec(cmd) -> str:
  return subprocess.run([cmd], capture_output=True, text=True, check=True).stdout.strip()

def hash(data) -> str:
  return hashlib.sha256(data.encode()).hexdigest()

def main():

  args = sys.argv[1:]

  block0 = 'public'
# block0 = exec('machine_id') + '/' + exec('boot_id') + '/' + exec('openpgp4fpr')
# block0 = exec('openpgp4fpr')
  block0 = hash(block0)

  block1 = block0 + '\n' + '\n'.join(args) + '\n'
  block1 = hash(block1)

  print(block1)

if __name__ == '__main__':
  main()
