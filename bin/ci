#!/bin/bash

set -o errexit
set -o nounset
set -o pipefail

(

  find "${HOME}/src" -name 'Makefile' -or -name 'build.xml' -or -name 'pom.xml' -or -name 'package.json' -or -name 'Dockerfile' 2> /dev/null | while read target; do
    pushd "${target%/*}" &> /dev/null
      build
#     test
#     push
    popd &> /dev/null
  done

  # test

  # doc

  # rel
  find "${HOME}/src" -name 'deploy.yml' 2> /dev/null | while read target; do
    pushd "${target%/*}" &> /dev/null
      deploy
    popd &> /dev/null
  done

)
