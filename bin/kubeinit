#!/bin/bash

set -o errexit
set -o nounset
set -o pipefail

(

  host="$(hostname)"

# kind delete cluster --name "${host}" || true

  if ! kubectl config get-contexts "kind-${host}" &> /dev/null ; then

    if is_sudoer; then
#     sudo sysctl --write fs.inotify.max_user_instances=1024
#     sudo sysctl --write fs.inotify.max_user_watches=65536
      sudo sysctl --write net.ipv4.ip_unprivileged_port_start=80
    fi

    cat "${HOME}/src/0.kind/kind.yml" | varsubst | KIND_EXPERIMENTAL_PROVIDER=podman kind create cluster --name "${host}" --config -

    if is_sudoer; then
#     sudo sysctl --write fs.inotify.max_user_instances=128
#     sudo sysctl --write fs.inotify.max_user_watches=8192
      sudo sysctl --write net.ipv4.ip_unprivileged_port_start=1024
    fi

    kubectl config set-context     "kind-${host}"
    kubectl cluster-info --context "kind-${host}"

    kubectl get configmap kube-proxy --namespace kube-system --output yaml | sed 's/strictARP: false/strictARP: true/' | kubectl apply -f -

    # loadbalancer
#   cat             "${HOME}/src/com.github/metallb/metallb/config/manifests/metallb-native.yaml"                  | kubectl apply -f -
    curl 'https://raw.githubusercontent.com/metallb/metallb/main/config/manifests/metallb-native.yaml'             | kubectl apply -f -

    # ingress
#   cat             "${HOME}/src/com.github/kubernetes/ingress-nginx/deploy/static/provider/kind/deploy.yaml"      | kubectl apply -f -
    curl 'https://raw.githubusercontent.com/kubernetes/ingress-nginx/main/deploy/static/provider/kind/deploy.yaml' | kubectl apply -f -

    kubectl wait --namespace ingress-nginx --for=condition=ready pod --selector=app.kubernetes.io/component=controller --timeout=120s

    # dashboard
#   cat             "${HOME}/src/com.github/kubernetes/dashboard/aio/deploy/recommended.yaml"                      | kubectl apply -f -
#   curl 'https://raw.githubusercontent.com/kubernetes/dashboard/main/aio/deploy/recommended.yaml'                 | kubectl apply -f -

  fi

  kubectl config get-contexts

)
