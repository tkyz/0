#!/bin/bash

set -o errexit
set -o nounset
set -o pipefail

# TODO: 引数ではなく標準入力からパラメータが渡ってくる
stdin=($(cat /dev/stdin))

printf "\e[2m"

  echo   '---'
  echo   'env:'
  export | sed 's/declare -x /  - /g'

  echo   "${0}:"
  echo   "  pwd: ${PWD}"
  echo   "  cmd: ${BASH_SOURCE:-0}"
  echo   '  stdin:'
  for item in "${stdin[@]}"; do
    echo "    - ${item}"
  done

printf "\e[0m"

exit 0
